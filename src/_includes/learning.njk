{# Macro to render a single learning item as a card #}
{% macro renderCard(item) %}
    {% set display_name = item.name | default('') | trim %}
    {% set icon_class = item.type | typeIcon %}
    {% set is_tweet = item.type == 'tweet' or item.type == 'thread' %}
    {% set is_video = item.type == 'video' %}
    {% set raw_type = item.type | default('') | trim %}
    {% set display_type = raw_type | replace('_', ' ') | title if raw_type else 'Resource' %}
    {% set search_blob = (display_name + ' ' + (item.author | default('')) + ' ' + display_type + ' ' + (item.notes | default(''))) | lower %}
    {# For tweets: short title (first 3 words), strip URLs from notes #}
    {% set tweet_title = display_name | stripUrls | truncateWords(3) if is_tweet else display_name %}
    {% set tweet_text = item.notes | stripUrls if is_tweet else item.notes %}

    <div class="learning-card-wrapper" data-haystack="{{ search_blob }}">
        <div class="learning-card">
            <div class="learning-card-header">
                <div class="learning-card-icon{{ ' tweet-icon' if is_tweet else '' }}">
                    <i class="{{ icon_class }}"></i>
                </div>
                <div class="learning-card-title-group">
                    <h4 class="learning-card-title">
                        {% if item.link and not is_tweet %}
                            <a href="{{ item.link }}" target="_blank" rel="noopener">{{ display_name }}</a>
                        {% elif is_tweet %}
                            {{ tweet_title }}
                        {% else %}
                            {{ display_name }}
                        {% endif %}
                    </h4>
                    {% if item.author or item.student %}
                        <p class="learning-card-author">{{ item.author | default(item.student) | trim }}</p>
                    {% endif %}
                </div>
            </div>
            {% if is_video and item.youtube_thumbnail %}
                <div class="learning-card-thumbnail">
                    <a href="{{ item.link }}" target="_blank" rel="noopener">
                        <img src="/{{ item.youtube_thumbnail }}" alt="{{ display_name }} thumbnail" loading="lazy">
                        <div class="learning-card-play-overlay">
                            <i class="fa-solid fa-play"></i>
                        </div>
                    </a>
                </div>
            {% endif %}
            {% if is_tweet and item.media %}
                {% set media_data = item.media | parseJson %}
                {% if media_data and media_data.images and media_data.images.length > 0 %}
                    <div class="learning-card-media">
                        {% for img in media_data.images %}
                            <img src="/static/img/tweets/{{ img }}" alt="Tweet media" loading="lazy">
                        {% endfor %}
                    </div>
                {% endif %}
            {% endif %}
            {% if (item.notes and not is_tweet) or (is_tweet and tweet_text) %}
                <div class="learning-card-body">
                    {% if is_tweet %}
                        <p>{{ tweet_text }}</p>
                    {% elif item.notes %}
                        <p>{{ item.notes }}</p>
                    {% endif %}
                </div>
            {% endif %}
            <div class="learning-card-footer">
                <span class="learning-card-type">{{ display_type }}</span>
                {% if is_tweet and item.link %}
                    <a href="{{ item.link }}" target="_blank" rel="noopener" class="learning-card-link" title="View on X">
                        <i class="fa-brands fa-x-twitter"></i>
                    </a>
                {% endif %}
                <span class="learning-card-date">
                    {% if item.date_added_display %}
                        {{ item.date_added_display }}
                    {% endif %}
                </span>
            </div>
        </div>
    </div>
{% endmacro %}

<div class="row">
    <div class="page-header">
        <h2 id="learning"><i class="fa-solid fa-brain"></i> Learning</h2>
    </div>
</div>

<div class="row">
    <p style="margin-bottom: 24px;">
        This is a list of the things I watch, read, or listen to that I find interesting!
    </p>
</div>

{# Filter learning resources and sort by date #}
{% set learning_entries = resources | filterLearning %}
{% set sorted_learning = learning_entries | sortByKey('date_added_sort_key', true) %}
{% set current_year = '' | currentYear %}

{% if sorted_learning | length > 0 %}
    {# Search input #}
    <div class="row">
        <div class="col-sm-12">
            <div class="form-group" style="margin-bottom: 20px;">
                <label for="learning-search" class="sr-only">Search learning resources</label>
                <div class="input-group">
                    <span class="input-group-addon"><i class="fa fa-search"></i></span>
                    <input type="text" id="learning-search" class="form-control" placeholder="Search learning resources by title, author, type, or notes&hellip;">
                </div>
            </div>
        </div>
    </div>

    {% if sorted_learning | length > 5 %}
        {# Group by year #}
        {% set grouped_learning = sorted_learning | groupByYear %}
        {% set ordered_years = grouped_learning | sortedYearKeys %}

        <div class="row" style="margin-top: 15px;">
            <div class="col-sm-12">
                <div class="panel-group" id="learning-archive" role="tablist">
                {% for year in ordered_years %}
                    {% set year_slug = 'learning-year-' + (year | slugify) %}
                    {% set year_entries = grouped_learning[year] %}
                    {% set is_current_year = (year | string) == (current_year | string) %}
                    {% set collapse_class = 'in' if is_current_year else '' %}

                    <div class="panel panel-default" style="border-radius: 4px; overflow: hidden; margin-bottom: 10px;">
                        <div class="panel-heading" role="tab" id="{{ year_slug }}-heading" style="padding: 0;">
                            <button class="btn btn-link btn-block" type="button" data-toggle="collapse" data-target="#{{ year_slug }}" aria-expanded="{{ 'true' if is_current_year else 'false' }}" aria-controls="{{ year_slug }}" style="text-align: left; padding: 12px 15px;">
                                {{ year }} <span class="badge">{{ year_entries | length }}</span>
                                <i class="fa fa-caret-down pull-right"></i>
                            </button>
                        </div>
                        <div id="{{ year_slug }}" class="panel-collapse collapse {{ collapse_class }}" role="tabpanel" aria-labelledby="{{ year_slug }}-heading">
                            <div class="learning-card-container" style="padding: 12px;">
                            {% for item in year_entries %}
                                {{ renderCard(item) }}
                            {% endfor %}
                            {% if year_entries | length == 0 %}
                                <p class="text-muted">No learning resources recorded for {{ year }}.</p>
                            {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
                </div>
            </div>
        </div>
    {% else %}
        {# Simple card grid for 5 or fewer items #}
        <div class="row">
            <div class="col-sm-12">
                <div class="learning-card-container">
                {% for item in sorted_learning %}
                    {{ renderCard(item) }}
                {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}

    <script>
    window.addEventListener("load", function() {
        if (window.jQuery) {
            var $learningCards = window.jQuery('.learning-card-wrapper');
            window.jQuery('#learning-search').on('input', function() {
                var term = window.jQuery(this).val().toLowerCase().trim();
                $learningCards.each(function() {
                    var $card = window.jQuery(this);
                    var haystack = ($card.data('haystack') || '').toString();
                    var fallback = $card.text().toLowerCase();
                    var matches = term === '' || haystack.indexOf(term) !== -1 || fallback.indexOf(term) !== -1;
                    $card.toggle(matches);
                });
            });
        }
    });
    </script>
{% else %}
    <div class="row">
        <div class="col-sm-12">
            <p class="text-muted">Learning resources will appear here once they are added to <code>static/csv/resources.csv</code> with an <code>export_id</code> containing "learning".</p>
        </div>
    </div>
{% endif %}
