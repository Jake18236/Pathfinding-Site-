<div class="row">
    <div class="page-header">
        <h2 id="visualizations"><i class="fa-solid fa-eye"></i>Visualizations</h2>
    </div>
</div>

<div class="row">
    <p style="margin-bottom: 24px;">
        Explore core AI algorithms through interactive visualizations. These tools are designed to help
        you understand how fundamental algorithms work by watching them execute step-by-step.
    </p>
</div>

<div class="row">
    <div class="col-sm-12">
        <div class="form-group" style="margin-bottom: 20px;">
            <label for="viz-search" class="sr-only">Search visualizations</label>
            <div class="input-group">
                <span class="input-group-addon"><i class="fa fa-search"></i></span>
                <input type="text" id="viz-search" class="form-control" placeholder="Search visualizations by title, description, or tags&hellip;">
            </div>
        </div>
    </div>
</div>

<div id="viz-card-container">
    {% for viz in collections.visualizations %}
    <div class="viz-card-wrapper" data-haystack="{{ viz.data.cardHaystack }}">
        <div class="viz-card">
            <a href="{{ viz.url | replace(r/^\//, '') }}" class="viz-card-link">
                <div class="viz-card-preview">
                    {% if viz.data.cardImage %}
                        <img src="{{ viz.data.cardImage }}" alt="{{ viz.data.cardTitle }} preview" loading="lazy">
                    {% else %}
                        <div class="viz-card-placeholder">
                            <i class="fa {{ viz.data.cardIcon }}"></i>
                        </div>
                    {% endif %}
                </div>
                <div class="viz-card-body">
                    <h4 class="viz-card-title">{{ viz.data.cardTitle }}</h4>
                    <p class="viz-card-description">{{ viz.data.cardDescription }}</p>
                    <div class="viz-card-tags">
                        {% for tag in viz.data.cardTags %}
                        <span class="viz-tag">{{ tag }}</span>
                        {% endfor %}
                    </div>
                </div>
            </a>
        </div>
    </div>
    {% endfor %}
</div>

<script>
window.addEventListener("load", function() {
    if (window.jQuery) {
        var $vizContainer = window.jQuery('#viz-card-container');
        var $vizCards = window.jQuery('.viz-card-wrapper');
        window.jQuery('#viz-search').on('input', function() {
            var term = window.jQuery(this).val().toLowerCase().trim();
            $vizCards.each(function() {
                var $card = window.jQuery(this);
                var haystack = ($card.data('haystack') || '').toString();
                var fallback = $card.text().toLowerCase();
                var matches = term === '' || haystack.indexOf(term) !== -1 || fallback.indexOf(term) !== -1;
                $card.toggle(matches);
            });
        });
    }
});
</script>

<style>
#viz-card-container {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 10px;
    max-height: 540px;
    overflow-y: auto;
    padding-right: 8px;
}

.viz-card-wrapper {
    flex: 1 1 calc(25% - 16px);
    max-width: calc(25% - 16px);
    min-width: 200px;
    display: flex;
}

.viz-card {
    display: flex;
    flex-direction: column;
    width: 100%;
    border-radius: 6px;
    border: 1px solid #ddd;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
    overflow: hidden;
    background: #fff;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.viz-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.12);
}

.viz-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
}

.viz-card-link:hover,
.viz-card-link:focus {
    text-decoration: none;
    color: inherit;
}

/* Screenshot preview thumbnail */
.viz-card-preview {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #f7f7f7;
    border-bottom: 1px solid #e0e0e0;
}

.viz-card-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
}

.viz-card:hover .viz-card-preview img {
    transform: scale(1.03);
}

.viz-card-placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
}

.viz-card-placeholder i {
    font-size: 3em;
    color: #bbb;
}

/* Card body with text content */
.viz-card-body {
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    flex: 1;
}

.viz-card-title {
    font-size: 0.95em;
    font-weight: 600;
    margin: 0 0 6px 0;
    color: #1a1a2e;
    line-height: 1.35;
}

.viz-card-description {
    font-size: 0.82em;
    color: #666;
    line-height: 1.5;
    margin: 0 0 10px 0;
    flex: 1;
}

.viz-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
}

.viz-tag {
    font-size: 0.72em;
    padding: 3px 8px;
    border-radius: 4px;
    background: #f0f0f5;
    color: #555;
    font-weight: 500;
}

/* Dark theme support */
[data-theme="gruvbox-dark"] .viz-card {
    background: #282828;
    border-color: #504945;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.45);
}

[data-theme="gruvbox-dark"] .viz-card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
}

[data-theme="gruvbox-dark"] .viz-card-preview {
    background: #32302f;
    border-bottom-color: #504945;
}

[data-theme="gruvbox-dark"] .viz-card-placeholder i {
    color: #665c54;
}

[data-theme="gruvbox-dark"] .viz-card-title {
    color: #ebdbb2;
}

[data-theme="gruvbox-dark"] .viz-card-description {
    color: #a89984;
}

[data-theme="gruvbox-dark"] .viz-tag {
    background: #3c3836;
    color: #bdae93;
}
</style>
