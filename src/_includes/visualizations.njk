<div class="row">
    <div class="page-header">
        <h2 id="visualizations"><i class="fa-solid fa-eye"></i> Interactive Visualizations</h2>
    </div>
</div>

<div class="row">
    <p style="margin-bottom: 24px;">
        Explore core AI algorithms through interactive visualizations. These tools are designed to help
        you understand how fundamental algorithms work by watching them execute step-by-step.
    </p>
</div>

<div class="row">
    <div class="col-sm-12">
        <div class="form-group" style="margin-bottom: 20px;">
            <label for="viz-search" class="sr-only">Search visualizations</label>
            <div class="input-group">
                <span class="input-group-addon"><i class="fa fa-search"></i></span>
                <input type="text" id="viz-search" class="form-control" placeholder="Search visualizations by title, description, or tags&hellip;">
            </div>
        </div>
    </div>
</div>

<div class="row" id="viz-card-container">
    {% for viz in collections.visualizations %}
    <div class="col-lg-3 col-md-6 col-sm-6 viz-card-wrapper" style="margin-bottom: 20px;" data-haystack="{{ viz.data.cardHaystack }}">
        <div class="viz-card">
            <a href="{{ viz.url | replace(r/^\//, '') }}" class="viz-card-link">
                <div class="viz-card-header">
                    <div class="viz-card-icon">
                        <i class="fa {{ viz.data.cardIcon }}"></i>
                    </div>
                    <h4 class="viz-card-title">{{ viz.data.cardTitle }}</h4>
                </div>
                <p class="viz-card-description">{{ viz.data.cardDescription }}</p>
                <div class="viz-card-tags">
                    {% for tag in viz.data.cardTags %}
                    <span class="viz-tag">{{ tag }}</span>
                    {% endfor %}
                </div>
            </a>
        </div>
    </div>
    {% endfor %}
</div>

<script>
window.addEventListener("load", function() {
    if (window.jQuery) {
        var $vizContainer = window.jQuery('#viz-card-container');
        var $vizCards = window.jQuery('.viz-card-wrapper');
        window.jQuery('#viz-search').on('input', function() {
            var term = window.jQuery(this).val().toLowerCase().trim();
            $vizCards.each(function() {
                var $card = window.jQuery(this);
                var haystack = ($card.data('haystack') || '').toString();
                var fallback = $card.text().toLowerCase();
                var matches = term === '' || haystack.indexOf(term) !== -1 || fallback.indexOf(term) !== -1;
                $card.toggle(matches);
            });
        });
    }
});
</script>

<style>
.viz-card {
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
}

.viz-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.12);
}

.viz-card-link {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 20px;
    text-decoration: none;
    color: inherit;
}

.viz-card-link:hover,
.viz-card-link:focus {
    text-decoration: none;
    color: inherit;
}

.viz-card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
}

.viz-card-icon {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: #002b5c;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.viz-card-icon i {
    font-size: 18px;
    color: #fff;
}

.viz-card-title {
    font-size: 1.1em;
    font-weight: 600;
    margin: 0;
    color: #1a1a2e;
}

.viz-card-description {
    font-size: 0.88em;
    color: #666;
    line-height: 1.5;
    margin: 0 0 14px 0;
    flex: 1;
}

.viz-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: auto;
}

.viz-tag {
    font-size: 0.72em;
    padding: 3px 8px;
    border-radius: 4px;
    background: #f0f0f5;
    color: #555;
    font-weight: 500;
}

/* Dark theme support */
[data-theme="gruvbox-dark"] .viz-card {
    background: #282828;
    border-color: #504945;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
}

[data-theme="gruvbox-dark"] .viz-card:hover {
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
}

[data-theme="gruvbox-dark"] .viz-card-title {
    color: #ebdbb2;
}

[data-theme="gruvbox-dark"] .viz-card-description {
    color: #a89984;
}

[data-theme="gruvbox-dark"] .viz-tag {
    background: #3c3836;
    color: #bdae93;
}

[data-theme="gruvbox-dark"] .viz-card-icon {
    background: #458588;
}
</style>
