---
layout: base.njk
title: Constraint Satisfaction Problem Visualizer
icon: fa-puzzle-piece
navigation:
  - name: "Home"
    link: "index.html"
    icon: "fa-home"
permalink: "shidoku.html"
extraScript: "static/js/shidoku.js"
---

<link rel="stylesheet" href="static/css/shidoku.css">

<!-- Top Row: Grid + Info Panel (2 columns) -->
<div class="row" id="grid">
    <!-- Left Column: Puzzle Grid -->
    <div class="col-md-5">
        <div class="panel panel-default">
            <div class="panel-heading">
                <div class="btn-group puzzle-header-tabs" role="group">
                    <button type="button" class="btn btn-sm btn-default active" data-puzzle="easy" title="8 clues">Easy</button>
                    <button type="button" class="btn btn-sm btn-default" data-puzzle="medium" title="6 clues">Medium</button>
                    <button type="button" class="btn btn-sm btn-default" data-puzzle="hard" title="4 clues">Hard</button>
                    <button type="button" class="btn btn-sm btn-default" data-puzzle="empty" title="Blank grid">Custom</button>
                </div>
            </div>
            <div class="panel-body text-center">
                <div id="shidoku-grid" class="shidoku-grid">
                    <!-- Grid cells will be generated by JavaScript -->
                </div>
                <div class="grid-legend">
                    <span class="legend-item"><span class="legend-color legend-fixed"></span> Fixed</span>
                    <span class="legend-item"><span class="legend-color legend-assigned"></span> Assigned</span>
                    <span class="legend-item"><span class="legend-color legend-examining"></span> Trying</span>
                    <span class="legend-item"><span class="legend-color legend-conflict"></span> Backtrack</span>
                    <span class="legend-item"><span class="legend-color legend-arc-source"></span> Arc Xi</span>
                    <span class="legend-item"><span class="legend-color legend-arc-target"></span> Arc Xj</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Tabbed Info Panel -->
    <div class="col-md-7">
        <div class="panel panel-default">
            <div class="panel-heading">
                <div class="btn-group info-panel-tabs" role="group">
                    <button type="button" class="btn btn-sm btn-default active" data-tab="about">
                        <i class="fa fa-info-circle"></i> About
                    </button>
                    <button type="button" class="btn btn-sm btn-default" data-tab="tree">
                        <i class="fa fa-sitemap"></i> Search Tree
                    </button>
                    <button type="button" class="btn btn-sm btn-default" data-tab="log">
                        <i class="fa fa-terminal"></i> Execution Log
                    </button>
                    <button type="button" class="btn btn-sm btn-default" data-tab="compare">
                        <i class="fa fa-table"></i> Compare
                    </button>
                </div>
            </div>
            <div class="panel-body info-panel-body">
                <!-- About Tab -->
                <div id="tab-about" class="info-tab-content active">
                    <h4><i class="fa fa-puzzle-piece"></i> What is Shidoku?</h4>
                    <p>
                        <strong>Shidoku</strong> is a 4x4 variant of Sudoku, perfect for learning constraint satisfaction problems (CSPs).
                        Fill each row, column, and 2x2 box with the digits 1-4, with no repeats.
                    </p>
                    <h4><i class="fa fa-cogs"></i> Algorithms</h4>
                    <ul class="algorithm-list">
                        <li><strong>AC-3</strong> - Arc Consistency algorithm that prunes impossible values from domains before searching.</li>
                        <li><strong>Backtracking + MRV</strong> - Depth-first search with Minimum Remaining Values heuristic for variable selection.</li>
                        <li><strong>MAC</strong> - Maintaining Arc Consistency runs AC-3 after each assignment for more aggressive pruning.</li>
                    </ul>
                    <h4><i class="fa fa-keyboard-o"></i> Controls</h4>
                    <p>Click cells to enter clues (1-4). Use arrow keys to navigate. Press Delete/Backspace to clear a cell.</p>
                </div>

                <!-- Search Tree Tab -->
                <div id="tab-tree" class="info-tab-content">
                    <div id="search-tree-container" class="search-tree-container">
                        <svg id="search-tree-svg" class="search-tree-svg">
                            <!-- Tree will be rendered here -->
                        </svg>
                        <div id="tree-tooltip" class="tree-tooltip"></div>
                    </div>
                    <div class="tree-controls">
                        <div class="tree-legend-bar">
                            <span class="tree-legend-item"><span class="tree-legend-dot tree-dot-current"></span> Current</span>
                            <span class="tree-legend-item"><span class="tree-legend-dot tree-dot-success"></span> Solution</span>
                            <span class="tree-legend-item"><span class="tree-legend-dot tree-dot-backtracked"></span> Backtracked</span>
                        </div>
                        <div class="tree-controls-right">
                            <div class="tree-zoom-control">
                                <i class="fa fa-search-minus"></i>
                                <input type="range" id="tree-zoom-slider" min="20" max="150" value="100">
                                <i class="fa fa-search-plus"></i>
                            </div>
                            <span class="tree-info">
                                <span id="tree-depth">Depth: 0</span> |
                                <span id="tree-nodes">Nodes: 0</span>
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Execution Log Tab -->
                <div id="tab-log" class="info-tab-content">
                    <div class="log-header">
                        <button id="btn-clear-log" class="btn btn-xs btn-default pull-right">
                            <i class="fa fa-trash"></i> Clear
                        </button>
                    </div>
                    <div id="execution-log" class="execution-log">
                        <div class="log-entry log-info">
                            <span class="log-icon"><i class="fa fa-info-circle"></i></span>
                            <span class="log-message">Click on cells to enter clues (1-4), then click Solve to start.</span>
                        </div>
                    </div>
                </div>

                <!-- Compare Tab -->
                <div id="tab-compare" class="info-tab-content">
                    <div class="compare-table-container">
                        <table id="comparison-table" class="table table-bordered table-striped table-condensed">
                            <thead>
                                <tr>
                                    <th>Algorithm</th>
                                    <th>Assigns</th>
                                    <th>Backtracks</th>
                                    <th>Arc Checks</th>
                                    <th>Prunings</th>
                                    <th>Time (ms)</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bottom Row: Controls (3 columns) -->
<div class="row" id="controls">
    <!-- Algorithm Selection -->
    <div class="col-md-4">
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-cogs"></i> Algorithm</h3>
            </div>
            <div class="panel-body compact-panel">
                <div class="checkbox disabled-checkbox">
                    <label>
                        <input type="checkbox" checked disabled>
                        <strong>Backtracking</strong> (base)
                    </label>
                </div>
                <div class="checkbox">
                    <label>
                        <input type="checkbox" id="use-fc">
                        <strong>Forward Checking</strong>
                    </label>
                </div>
                <div class="checkbox">
                    <label>
                        <input type="checkbox" id="use-mrv">
                        <strong>MRV</strong> heuristic
                    </label>
                </div>
                <div class="checkbox">
                    <label>
                        <input type="checkbox" id="use-ac3">
                        <strong>AC-3</strong> preprocessing
                    </label>
                </div>
                <div class="checkbox">
                    <label>
                        <input type="checkbox" id="use-mac">
                        <strong>MAC</strong> (AC-3 after assign)
                    </label>
                </div>
            </div>
        </div>
    </div>

    <!-- Playback Controls -->
    <div class="col-md-4">
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-play-circle"></i> Playback</h3>
            </div>
            <div class="panel-body compact-panel">
                <div class="btn-toolbar playback-buttons" role="toolbar">
                    <button id="btn-solve" class="btn btn-success" title="Start solving">
                        <i class="fa fa-play"></i> Solve
                    </button>
                    <button id="btn-pause" class="btn btn-warning" title="Pause/Resume" disabled>
                        <i class="fa fa-pause"></i> Pause
                    </button>
                    <button id="btn-step" class="btn btn-info" title="Step forward" disabled>
                        <i class="fa fa-step-forward"></i> Step
                    </button>
                    <button id="btn-reset" class="btn btn-danger" title="Reset puzzle">
                        <i class="fa fa-refresh"></i> Reset
                    </button>
                </div>
                <div class="speed-control-inline">
                    <label><i class="fa fa-tachometer"></i> Speed:</label>
                    <input type="range" id="speed-slider" min="1" max="10" value="5">
                </div>
            </div>
        </div>
    </div>

    <!-- Metrics -->
    <div class="col-md-4">
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-bar-chart"></i> Metrics</h3>
            </div>
            <div class="panel-body compact-panel">
                <table class="table table-condensed metrics-table">
                    <tbody>
                        <tr>
                            <td><i class="fa fa-pencil"></i> Assigns</td>
                            <td id="metric-assignments" class="text-right metric-value">0</td>
                            <td><i class="fa fa-undo"></i> Backtracks</td>
                            <td id="metric-backtracks" class="text-right metric-value">0</td>
                        </tr>
                        <tr>
                            <td><i class="fa fa-exchange"></i> Arcs</td>
                            <td id="metric-arcs" class="text-right metric-value">0</td>
                            <td><i class="fa fa-cut"></i> Prunings</td>
                            <td id="metric-prunings" class="text-right metric-value">0</td>
                        </tr>
                        <tr>
                            <td><i class="fa fa-clock-o"></i> Time</td>
                            <td id="metric-time" class="text-right metric-value" colspan="3">0.00s</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
