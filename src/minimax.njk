---
layout: base.njk
title: Minimax & Alpha-Beta Pruning Visualizer
icon: fa-gamepad
navigation:
  - name: "Home"
    link: "index.html"
    icon: "fa-home"
permalink: "minimax.html"
extraScript: "static/js/minimax.js"
---

{% from "components/legend.njk" import legend %}
{% from "components/controls-bar.njk" import controlsBar %}
{% from "components/metrics-panel.njk" import metricsPanel %}
{% from "components/algorithm-options.njk" import algorithmOptions %}

<link rel="stylesheet" href="static/css/minimax.css">
<!-- Sigma.js v3 for high-performance WebGL graph rendering -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/graphology/0.25.4/graphology.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sigma@3.0.2/dist/sigma.min.js"></script>

{{ controlsBar(
    groups=[
        {type: 'button-group', label: 'Game', icon: 'fa-gamepad', id: 'game-selector', buttons: [
            {label: 'Tic-Tac-Toe', icon: 'fa-th', dataAttr: 'game', dataValue: 'tictactoe', active: true},
            {label: 'Nim', icon: 'fa-cubes', dataAttr: 'game', dataValue: 'nim'}
        ]},
        {type: 'number-stepper', label: 'Depth', minusId: 'depth-minus', plusId: 'depth-plus', valueId: 'depth-value', value: '2'},
        {type: 'checkbox', id: 'use-alphabeta', text: 'Alpha-Beta Pruning', checked: true},
        {type: 'select', label: 'Move Order', id: 'move-ordering', options: [
            {value: 'default', text: 'Default', selected: true},
            {value: 'center', text: 'Center first'},
            {value: 'best', text: 'Best first'},
            {value: 'worst', text: 'Worst first'},
            {value: 'random', text: 'Random'}
        ]},
        {type: 'select', label: 'Position', id: 'position-preset', class: 'position-control', options: [
            {value: 'empty', text: 'Empty Board', selected: true},
            {value: 'early', text: 'Early Game'},
            {value: 'mid', text: 'Mid Game'},
            {value: 'near-win', text: 'Near Win'},
            {value: 'forced', text: 'Forced Mate'}
        ]},
        {type: 'select', label: 'Piles', id: 'nim-preset', class: 'nim-only', visible: false, options: [
            {value: '1,2,3', text: '[1, 2, 3]'},
            {value: '3,4,5', text: '[3, 4, 5]', selected: true},
            {value: '1,3,5,7', text: '[1, 3, 5, 7]'},
            {value: '2,2', text: '[2, 2]'}
        ]}
    ],
    resetButton={id: 'btn-reset', label: 'Reset'}
) }}

<!-- Main Content: Tree (2/3) + Side Panel (1/3) -->
<div class="row" id="main-content">
    <!-- Game Tree (Primary View) -->
    <div class="col-md-8">
        <div class="panel panel-default tree-panel">
            <div class="panel-heading">
                <h3 class="panel-title">
                    <i class="fa fa-sitemap"></i> Game Tree
                    <span class="tree-stats pull-right">
                        <span id="tree-nodes">0 nodes</span> |
                        <span id="tree-depth">depth 0</span> |
                        <span id="metric-time">0.00ms</span>
                    </span>
                </h3>
            </div>
            <div class="panel-body tree-panel-body">
                <div id="game-tree-container" class="game-tree-container-main">
                    <!-- Cytoscape.js renders here -->
                    <div id="depth-line-overlay" class="depth-line-overlay">
                        <div id="depth-line" class="depth-line"></div>
                        <span id="depth-line-label" class="depth-line-label">Depth limit: 2</span>
                    </div>
                    <div id="tree-tooltip" class="tree-tooltip"></div>
                </div>
                <div class="tree-controls-bar">
                    {{ legend(
                        items=[
                            {class: 'tree-dot-max', label: 'MAX (X)'},
                            {class: 'tree-dot-min', label: 'MIN (O)'},
                            {class: 'tree-dot-pruned', label: 'Pruned'},
                            {class: 'tree-dot-optimal', label: 'Optimal'}
                        ],
                        className='tree-legend-bar'
                    ) }}
                    <div class="tree-zoom-controls">
                        <button class="btn btn-xs btn-default" id="btn-zoom-fit" title="Fit to view">
                            <i class="fa fa-arrows-alt"></i>
                        </button>
                        <i class="fa fa-search-minus"></i>
                        <input type="range" id="tree-zoom-slider" min="20" max="400" value="400">
                        <i class="fa fa-search-plus"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Side Panel -->
    <div class="col-md-4">
        <!-- Hidden containers for JS state (not displayed) -->
        <div style="display: none;">
            <div id="tictactoe-container">
                <div id="tictactoe-grid" class="tictactoe-grid"></div>
            </div>
            <div id="nim-container">
                <div id="nim-piles" class="nim-piles"></div>
            </div>
            <span id="current-player"></span>
            <span id="game-result"></span>
        </div>

        <!-- Node Details Panel (custom - requires special JS interaction) -->
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-info-circle"></i> Node Details</h3>
            </div>
            <div class="panel-body node-details-body">
                <!-- Board Preview for Selected Node -->
                <div id="selected-board-preview" class="selected-board-preview" style="display: none;">
                    <div id="preview-grid" class="preview-grid"></div>
                </div>
                <div id="node-details" class="node-details">
                    <div class="node-detail-row">
                        <span class="node-detail-label">Player:</span>
                        <span id="detail-player" class="node-detail-value">-</span>
                    </div>
                    <div class="node-detail-row">
                        <span class="node-detail-label">Depth:</span>
                        <span id="detail-depth" class="node-detail-value">-</span>
                    </div>
                    <div class="node-detail-row">
                        <span class="node-detail-label">Value:</span>
                        <span id="detail-value" class="node-detail-value">-</span>
                    </div>
                    <div class="node-detail-row alpha-beta-row">
                        <span class="node-detail-label">Alpha:</span>
                        <span id="detail-alpha" class="node-detail-value alpha-value">-</span>
                    </div>
                    <div class="node-detail-row alpha-beta-row">
                        <span class="node-detail-label">Beta:</span>
                        <span id="detail-beta" class="node-detail-value beta-value">-</span>
                    </div>
                    <div class="node-detail-row">
                        <span class="node-detail-label">Status:</span>
                        <span id="detail-status" class="node-detail-value">-</span>
                    </div>
                    <div class="node-detail-row" id="detail-move-row" style="display: none;">
                        <span class="node-detail-label">Move:</span>
                        <span id="detail-move" class="node-detail-value">-</span>
                    </div>
                </div>
                <div id="no-node-selected" class="no-node-message">
                    <i class="fa fa-mouse-pointer"></i>
                    Click a node in the tree to see details
                </div>
            </div>
        </div>

        {{ metricsPanel(
            title='Metrics',
            layout='grid',
            rows=[
                [{icon: 'fa-tree', label: 'Evaluated', id: 'metric-evaluated', default: '0'},
                 {icon: 'fa-expand', label: 'Expanded', id: 'metric-expanded', default: '0'}],
                [{icon: 'fa-cut', label: 'a-Cutoffs', id: 'metric-alpha-cuts', default: '0'},
                 {icon: 'fa-cut', label: 'b-Cutoffs', id: 'metric-beta-cuts', default: '0'}]
            ]
        ) }}

        {{ algorithmOptions(
            title='Heuristic Function',
            icon='fa-sliders',
            options=[
                {type: 'custom', content: '<p class="heuristic-description"><code>h(state)</code> evaluates non-terminal positions.<br><span class="max-text">+</span> favors X, <span class="min-text">-</span> favors O</p>'},
                {type: 'number', label: 'Win', id: 'h-win', min: 0, max: 1000, value: 100, icon: 'fa-trophy', title: 'Points for winning the game'},
                {type: 'number', label: 'Two-in-row', id: 'h-two-row', min: 0, max: 100, value: 10, icon: 'fa-minus', title: 'Points for two-in-a-row with empty third cell'},
                {type: 'number', label: 'One-in-row', id: 'h-one-row', min: 0, max: 100, value: 1, icon: 'fa-minus', title: 'Points for one piece in a line with two empty'},
                {type: 'number', label: 'Center', id: 'h-center', min: 0, max: 100, value: 3, icon: 'fa-dot-circle-o', title: 'Points for controlling the center square'},
                {type: 'number', label: 'Corner', id: 'h-corner', min: 0, max: 100, value: 2, icon: 'fa-square-o', title: 'Points for controlling a corner square'},
                {type: 'custom', content: '<button id="btn-apply-heuristic" class="btn btn-sm btn-primary btn-block"><i class="fa fa-refresh"></i> Apply & Recompute</button>'}
            ]
        ) }}
    </div>
</div>
