---
layout: base.njk
title: Minimax & Alpha-Beta Pruning Visualizer
icon: fa-gamepad
navigation:
  - name: "Home"
    link: "index.html"
    icon: "fa-home"
permalink: "minimax.html"
extraScript: "static/js/minimax.js"
---

<link rel="stylesheet" href="static/css/minimax.css">
<!-- Sigma.js v3 for high-performance WebGL graph rendering -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/graphology/0.25.4/graphology.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sigma@3.0.2/dist/sigma.min.js"></script>

<!-- Top Controls Bar -->
<div class="row" id="controls-bar">
    <div class="col-md-12">
        <div class="panel panel-default controls-panel">
            <div class="panel-body controls-bar-body">
                <div class="controls-row">
                    <!-- Game Selection -->
                    <div class="control-group">
                        <label><i class="fa fa-gamepad"></i> Game:</label>
                        <div class="btn-group game-selector" role="group">
                            <button type="button" class="btn btn-sm btn-default active" data-game="tictactoe">
                                <i class="fa fa-th"></i> Tic-Tac-Toe
                            </button>
                            <button type="button" class="btn btn-sm btn-default" data-game="nim">
                                <i class="fa fa-cubes"></i> Nim
                            </button>
                        </div>
                    </div>

                    <!-- Depth Control -->
                    <div class="control-group">
                        <label>Depth:</label>
                        <div class="depth-buttons">
                            <button type="button" class="btn btn-sm btn-default" id="depth-minus">
                                <i class="fa fa-minus"></i>
                            </button>
                            <span id="depth-value" class="depth-display">2</span>
                            <button type="button" class="btn btn-sm btn-default" id="depth-plus">
                                <i class="fa fa-plus"></i>
                            </button>
                        </div>
                    </div>

                    <!-- Alpha-Beta Toggle -->
                    <div class="control-group">
                        <label class="checkbox-inline">
                            <input type="checkbox" id="use-alphabeta" checked>
                            <strong>Alpha-Beta Pruning</strong>
                        </label>
                    </div>

                    <!-- Move Ordering -->
                    <div class="control-group">
                        <label>Move Order:</label>
                        <select id="move-ordering" class="form-control input-sm">
                            <option value="default">Default</option>
                            <option value="center">Center first</option>
                            <option value="best">Best first</option>
                            <option value="worst">Worst first</option>
                            <option value="random">Random</option>
                        </select>
                    </div>

                    <!-- Start Position -->
                    <div class="control-group" id="position-control">
                        <label>Position:</label>
                        <select id="position-preset" class="form-control input-sm">
                            <option value="empty">Empty Board</option>
                            <option value="early">Early Game</option>
                            <option value="mid">Mid Game</option>
                            <option value="near-win">Near Win</option>
                            <option value="forced">Forced Mate</option>
                        </select>
                    </div>

                    <!-- Nim Controls (hidden by default) -->
                    <div class="control-group nim-only" style="display: none;">
                        <label>Piles:</label>
                        <select id="nim-preset" class="form-control input-sm">
                            <option value="1,2,3">[1, 2, 3]</option>
                            <option value="3,4,5" selected>[3, 4, 5]</option>
                            <option value="1,3,5,7">[1, 3, 5, 7]</option>
                            <option value="2,2">[2, 2]</option>
                        </select>
                    </div>

                    <!-- Reset Button -->
                    <div class="control-group">
                        <button id="btn-reset" class="btn btn-sm btn-danger" title="Reset">
                            <i class="fa fa-refresh"></i> Reset
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Main Content: Tree (2/3) + Side Panel (1/3) -->
<div class="row" id="main-content">
    <!-- Game Tree (Primary View) -->
    <div class="col-md-8">
        <div class="panel panel-default tree-panel">
            <div class="panel-heading">
                <h3 class="panel-title">
                    <i class="fa fa-sitemap"></i> Game Tree
                    <span class="tree-stats pull-right">
                        <span id="tree-nodes">0 nodes</span> |
                        <span id="tree-depth">depth 0</span> |
                        <span id="metric-time">0.00ms</span>
                    </span>
                </h3>
            </div>
            <div class="panel-body tree-panel-body">
                <div id="game-tree-container" class="game-tree-container-main">
                    <!-- Cytoscape.js renders here -->
                    <div id="depth-line-overlay" class="depth-line-overlay">
                        <div id="depth-line" class="depth-line"></div>
                        <span id="depth-line-label" class="depth-line-label">Depth limit: 2</span>
                    </div>
                    <div id="tree-tooltip" class="tree-tooltip"></div>
                </div>
                <div class="tree-controls-bar">
                    <div class="tree-legend-bar">
                        <span class="tree-legend-item"><span class="tree-legend-dot tree-dot-max"></span> MAX (X)</span>
                        <span class="tree-legend-item"><span class="tree-legend-dot tree-dot-min"></span> MIN (O)</span>
                        <span class="tree-legend-item"><span class="tree-legend-dot tree-dot-pruned"></span> Pruned</span>
                        <span class="tree-legend-item"><span class="tree-legend-dot tree-dot-optimal"></span> Optimal</span>
                    </div>
                    <div class="tree-zoom-controls">
                        <button class="btn btn-xs btn-default" id="btn-zoom-fit" title="Fit to view">
                            <i class="fa fa-arrows-alt"></i>
                        </button>
                        <i class="fa fa-search-minus"></i>
                        <input type="range" id="tree-zoom-slider" min="20" max="400" value="400">
                        <i class="fa fa-search-plus"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Side Panel -->
    <div class="col-md-4">
        <!-- Hidden containers for JS state (not displayed) -->
        <div style="display: none;">
            <div id="tictactoe-container">
                <div id="tictactoe-grid" class="tictactoe-grid"></div>
            </div>
            <div id="nim-container">
                <div id="nim-piles" class="nim-piles"></div>
            </div>
            <span id="current-player"></span>
            <span id="game-result"></span>
        </div>

        <!-- Node Details Panel -->
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-info-circle"></i> Node Details</h3>
            </div>
            <div class="panel-body node-details-body">
                <!-- Board Preview for Selected Node -->
                <div id="selected-board-preview" class="selected-board-preview" style="display: none;">
                    <div id="preview-grid" class="preview-grid"></div>
                </div>
                <div id="node-details" class="node-details">
                    <div class="node-detail-row">
                        <span class="node-detail-label">Player:</span>
                        <span id="detail-player" class="node-detail-value">-</span>
                    </div>
                    <div class="node-detail-row">
                        <span class="node-detail-label">Depth:</span>
                        <span id="detail-depth" class="node-detail-value">-</span>
                    </div>
                    <div class="node-detail-row">
                        <span class="node-detail-label">Value:</span>
                        <span id="detail-value" class="node-detail-value">-</span>
                    </div>
                    <div class="node-detail-row alpha-beta-row">
                        <span class="node-detail-label">Alpha:</span>
                        <span id="detail-alpha" class="node-detail-value alpha-value">-</span>
                    </div>
                    <div class="node-detail-row alpha-beta-row">
                        <span class="node-detail-label">Beta:</span>
                        <span id="detail-beta" class="node-detail-value beta-value">-</span>
                    </div>
                    <div class="node-detail-row">
                        <span class="node-detail-label">Status:</span>
                        <span id="detail-status" class="node-detail-value">-</span>
                    </div>
                    <div class="node-detail-row" id="detail-move-row" style="display: none;">
                        <span class="node-detail-label">Move:</span>
                        <span id="detail-move" class="node-detail-value">-</span>
                    </div>
                </div>
                <div id="no-node-selected" class="no-node-message">
                    <i class="fa fa-mouse-pointer"></i>
                    Click a node in the tree to see details
                </div>
            </div>
        </div>

        <!-- Metrics Panel -->
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-bar-chart"></i> Metrics</h3>
            </div>
            <div class="panel-body compact-panel">
                <table class="table table-condensed metrics-table">
                    <tbody>
                        <tr>
                            <td><i class="fa fa-tree"></i> Evaluated</td>
                            <td id="metric-evaluated" class="text-right metric-value">0</td>
                            <td><i class="fa fa-expand"></i> Expanded</td>
                            <td id="metric-expanded" class="text-right metric-value">0</td>
                        </tr>
                        <tr>
                            <td><i class="fa fa-cut"></i> a-Cutoffs</td>
                            <td id="metric-alpha-cuts" class="text-right metric-value">0</td>
                            <td><i class="fa fa-cut"></i> b-Cutoffs</td>
                            <td id="metric-beta-cuts" class="text-right metric-value">0</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Heuristic Evaluation Function -->
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-sliders"></i> Heuristic Function</h3>
            </div>
            <div class="panel-body heuristic-panel">
                <p class="heuristic-description">
                    <code>h(state)</code> evaluates non-terminal positions.<br>
                    <span class="max-text">+</span> favors X, <span class="min-text">-</span> favors O
                </p>
                <div class="heuristic-inputs">
                    <div class="heuristic-row">
                        <label title="Points for winning the game">
                            <i class="fa fa-trophy"></i> Win
                        </label>
                        <input type="number" id="h-win" value="100" min="0" max="1000" class="heuristic-input">
                    </div>
                    <div class="heuristic-row">
                        <label title="Points for two-in-a-row with empty third cell">
                            <i class="fa fa-minus"></i><i class="fa fa-minus"></i> Two-in-row
                        </label>
                        <input type="number" id="h-two-row" value="10" min="0" max="100" class="heuristic-input">
                    </div>
                    <div class="heuristic-row">
                        <label title="Points for one piece in a line with two empty">
                            <i class="fa fa-minus"></i> One-in-row
                        </label>
                        <input type="number" id="h-one-row" value="1" min="0" max="100" class="heuristic-input">
                    </div>
                    <div class="heuristic-row">
                        <label title="Points for controlling the center square">
                            <i class="fa fa-dot-circle-o"></i> Center
                        </label>
                        <input type="number" id="h-center" value="3" min="0" max="100" class="heuristic-input">
                    </div>
                    <div class="heuristic-row">
                        <label title="Points for controlling a corner square">
                            <i class="fa fa-square-o"></i> Corner
                        </label>
                        <input type="number" id="h-corner" value="2" min="0" max="100" class="heuristic-input">
                    </div>
                </div>
                <button id="btn-apply-heuristic" class="btn btn-sm btn-primary btn-block">
                    <i class="fa fa-refresh"></i> Apply & Recompute
                </button>
            </div>
        </div>
    </div>
</div>
