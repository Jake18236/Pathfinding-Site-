{% from "components/legend.njk" import legend %}
{% from "components/info-tabs.njk" import infoTabs %}
{% from "components/stepper-control.njk" import stepperControl %}

<link rel="stylesheet" href="static/css/rnn.css">

<div class="row" id="main-content">
    {% include "components/share-button.njk" %}
    <!-- Left Column: Architecture Diagram -->
    <div class="col-md-7">
        <div class="panel panel-default">
            <div class="panel-heading">
                <div class="panel-heading-content">
                    <div class="btn-group btn-group-sm rnn-mode-toggle" role="group">
                        <button type="button" class="btn btn-default active" id="btn-mode-inference">
                            <i class="fa fa-play"></i> Inference
                        </button>
                        <button type="button" class="btn btn-default" id="btn-mode-training">
                            <i class="fa fa-graduation-cap"></i> Training
                        </button>
                    </div>
                    <select id="rnn-task-select" class="form-control input-sm rnn-task-select">
                        <option value="text-generation">Text Generation</option>
                        <option value="sentiment">Sentiment Analysis</option>
                        <option value="translation">Machine Translation</option>
                        <option value="ner">Named Entity Recognition</option>
                        <option value="summarization">Summarization</option>
                    </select>
                </div>
            </div>
            <div class="panel-body compact-panel">
                <div class="rnn-diagram" id="rnn-diagram" aria-label="RNN Architecture Diagram">
                    <!-- JS populates: input → embed → cell → output → predicted blocks with arrows -->
                </div>
            </div>
            <div class="panel-footer legend-footer">
                {{ legend(
                    items=[
                        {class: 'rnn-embed-legend', label: 'Embedding'},
                        {class: 'rnn-cell-legend', label: 'RNN Cell'},
                        {class: 'rnn-output-legend', label: 'Output'},
                        {class: 'rnn-flow-legend', label: 'Data Flow', type: 'dot'}
                    ]
                ) }}
            </div>
        </div>
    </div>

    <!-- Right Column: Info Tabs -->
    <div class="col-md-5">
        {{ infoTabs(
            tabs=[
                {id: 'about', icon: 'fa-info-circle', label: 'About', active: true, content: '
                    <h4><i class="fa fa-exchange"></i> RNN Architecture</h4>
                    <p>
                        A <strong>Recurrent Neural Network</strong> processes sequences one token at a time.
                        At each timestep, the input token is embedded, combined with the previous hidden state,
                        and transformed to produce an output prediction and a new hidden state.
                    </p>
                    <p>
                        The <strong>hidden state</strong> h<sub>t</sub> carries information from all previous
                        tokens forward through the sequence &mdash; this is what makes the network
                        <em>recurrent</em>.
                    </p>
                    <h4><i class="fa fa-mouse-pointer"></i> How to Use</h4>
                    <ul class="rnn-interaction-list">
                        <li><strong>Click a block</strong> on the diagram to expand it and see internal weights, matrices, and computations</li>
                        <li><strong>Click again</strong> or click empty space to collapse back to the overview</li>
                        <li><strong>Hover</strong> over any block for a quick summary tooltip</li>
                        <li><strong>Step through timesteps</strong> in the Controls tab to see how hidden state evolves</li>
                        <li><strong>Change dimensions</strong> to see how network size affects weight matrices</li>
                    </ul>
                '},
                {id: 'algorithm', icon: 'fa-book', label: 'Algorithm', content: '
                    <h4><i class="fa fa-book"></i> Forward Pass</h4>
                    <ol class="rnn-algo-steps">
                        <li><strong>Embed:</strong> Look up the input character in the embedding matrix E to get x<sub>t</sub></li>
                        <li><strong>Hidden state:</strong> Compute h<sub>t</sub> = tanh(W<sub>xh</sub>&middot;x<sub>t</sub> + W<sub>hh</sub>&middot;h<sub>t-1</sub> + b<sub>h</sub>)</li>
                        <li><strong>Output:</strong> Compute logits y<sub>t</sub> = W<sub>hy</sub>&middot;h<sub>t</sub> + b<sub>y</sub></li>
                        <li><strong>Softmax:</strong> Convert logits to probabilities over the vocabulary</li>
                        <li><strong>Predict:</strong> Select the highest-probability character</li>
                    </ol>
                    <h4><i class="fa fa-repeat"></i> Recurrence</h4>
                    <p style="font-size:13px;">
                        The key insight is that h<sub>t</sub> depends on h<sub>t-1</sub>, which depends on
                        h<sub>t-2</sub>, and so on. This chain allows the network to maintain a
                        &ldquo;memory&rdquo; of the entire sequence seen so far.
                    </p>
                    <div class="rnn-formula">
                        h<sub>0</sub> &rarr; h<sub>1</sub> &rarr; h<sub>2</sub> &rarr; &hellip; &rarr; h<sub>T</sub>
                    </div>
                '},
                {id: 'math', icon: 'fa-superscript', label: 'Math', content: '
                    <h4><i class="fa fa-superscript"></i> Live Computation</h4>
                    <div id="rnn-math-panel">
                        <span style="font-size:12px; color:var(--viz-text-muted);">
                            Step through timesteps to see live computations here.
                        </span>
                    </div>
                '},
                {id: 'controls', icon: 'fa-sliders', label: 'Controls', content: '
                    <div class="rnn-controls-panel">
                        <div class="option-row">
                            <label>Example:</label>
                            <select id="rnn-example-select" class="form-control input-sm">
                                <option value="0">hello world</option>
                                <option value="1">the cat sat</option>
                                <option value="2">abcabc</option>
                            </select>
                        </div>
                        <div class="option-row">
                            <label>Timestep:</label>
                            ' + stepperControl(id='rnn-timestep', value='0', title='Timestep') + '
                        </div>
                        <div class="option-row">
                            <label>Hidden Dim:</label>
                            <select id="rnn-hidden-dim" class="form-control input-sm">
                                <option value="16">16</option>
                                <option value="32">32</option>
                                <option value="64" selected>64</option>
                                <option value="128">128</option>
                            </select>
                        </div>
                        <div class="option-row">
                            <label>Embed Dim:</label>
                            <select id="rnn-embed-dim" class="form-control input-sm">
                                <option value="16">16</option>
                                <option value="32">32</option>
                                <option value="64">64</option>
                                <option value="128" selected>128</option>
                            </select>
                        </div>
                        <div class="rnn-actions-row">
                            <button id="rnn-btn-reset" class="btn btn-sm btn-danger" title="Reset visualization">
                                <i class="fa fa-undo"></i> Reset
                            </button>
                        </div>
                    </div>
                '}
            ]
        ) }}
    </div>
</div>
