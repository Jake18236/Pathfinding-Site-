---
layout: base.njk
title: RNN Inference Pipeline
icon: fa-exchange
navigation:
  - name: "Home"
    link: "index.html"
    icon: "fa-home"
permalink: "rnn.html"
extraScript: "static/js/rnn.js"
tags: visualization
cardTitle: "RNN & LSTM"
cardIcon: fa-exchange
cardDescription: "Watch an RNN inference pipeline process text: tokenization, embeddings, recurrent cells, softmax, and token prediction."
cardTags:
  - Deep Learning
  - Sequences
cardHaystack: "recurrent neural network rnn lstm hidden state sequence inference pipeline tokenizer embeddings softmax argmax prediction"
cardOrder: 24
cardImage: static/img/vis_cards/rnn.png
---

{% from "components/legend.njk" import legend %}
{% from "components/info-tabs.njk" import infoTabs %}
{% from "components/metrics-panel.njk" import metricsPanel %}

<link rel="stylesheet" href="static/css/rnn.css">

<div class="row" id="main-content">
    {% include "components/share-button.njk" %}
    <!-- Left Column: Pipeline Canvas + Controls -->
    <div class="col-md-7">
        <!-- Pipeline Diagram Panel -->
        <div class="panel panel-default">
            <div class="panel-heading">
                <div class="panel-heading-content">
                    <span class="panel-title-text"><i class="fa fa-exchange"></i> RNN Inference Pipeline</span>
                    <span class="viz-badge" id="arch-badge">Vanilla RNN</span>
                </div>
            </div>
            <div class="panel-body canvas-panel-body">
                <div class="canvas-wrapper">
                    <canvas id="pipeline-canvas" width="720" height="700"></canvas>
                </div>
            </div>
            <div class="panel-footer legend-footer">
                {{ legend(
                    items=[
                        {class: 'rnn-input-layer', label: 'Input/Embed'},
                        {class: 'rnn-cell-color', label: 'RNN Cell'},
                        {class: 'rnn-active-cell', label: 'Active'},
                        {class: 'rnn-output-layer', label: 'Output'},
                        {class: 'rnn-prob-color', label: 'Probability', type: 'dot'},
                        {class: 'rnn-hidden-dot', label: 'Hidden State', type: 'dot'}
                    ]
                ) }}
            </div>
        </div>

        <!-- Controls Panel -->
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-sliders"></i> Controls</h3>
            </div>
            <div class="panel-body compact-panel rnn-controls-panel">
                <div class="rnn-options-col">
                    <div class="rnn-input-row">
                        <label>Input Text:</label>
                        <input type="text" id="input-text" class="form-control input-sm" value="I like cute kittens and" />
                    </div>
                </div>
                <div class="rnn-actions-col">
                    <div class="btn-toolbar" role="toolbar">
                        <button id="btn-process" class="btn btn-sm btn-success" title="Process full pipeline">
                            <i class="fa fa-play"></i> Process
                        </button>
                        <button id="btn-step" class="btn btn-sm btn-info" title="Step one phase">
                            <i class="fa fa-step-forward"></i> Step
                        </button>
                        <button id="btn-reset" class="btn btn-sm btn-danger" title="Reset">
                            <i class="fa fa-refresh"></i> Reset
                        </button>
                    </div>
                    <div class="speed-control">
                        <i class="fa fa-tachometer"></i>
                        <input type="range" id="speed-slider" min="1" max="10" value="5">
                        <span id="speed-value" class="range-value">5</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Info + Metrics -->
    <div class="col-md-5">
        {{ infoTabs(
            tabs=[
                {id: 'about', icon: 'fa-info-circle', label: 'About', active: true, content: '
                    <h4><i class="fa fa-exchange"></i> RNN Inference Pipeline</h4>
                    <p>
                        This visualization shows the complete <strong>inference pipeline</strong> of a
                        Recurrent Neural Network processing text input, from raw text to predicted output tokens.
                    </p>
                    <p>
                        Data flows <strong>bottom-to-top</strong> through 9 layers: input text &rarr;
                        tokenizer &rarr; embeddings &rarr; RNN cells &rarr; softmax &rarr;
                        probability distribution &rarr; argmax &rarr; token decode &rarr; output tokens.
                    </p>
                    <h4><i class="fa fa-mouse-pointer"></i> How to Use</h4>
                    <ul class="interaction-list">
                        <li><strong>Enter input text</strong> in the text field</li>
                        <li><strong>Press Process</strong> to animate the full pipeline</li>
                        <li><strong>Press Step</strong> to advance one phase at a time</li>
                        <li><strong>Watch data flow</strong> bottom-to-top through each layer</li>
                        <li><strong>Adjust speed</strong> with the slider</li>
                    </ul>
                '},
                {id: 'algorithm', icon: 'fa-book', label: 'Algorithm', content: '
                    <h4><i class="fa fa-book"></i> Pipeline Stages</h4>
                    <ol class="algorithm-list">
                        <li><strong>Tokenize</strong>: Split text into word tokens</li>
                        <li><strong>Embed</strong>: Look up each token&rsquo;s embedding vector</li>
                        <li><strong>RNN Cell</strong>: h<sub>t</sub> = tanh(W<sub>h</sub>h<sub>t-1</sub> + W<sub>x</sub>e<sub>t</sub> + b)</li>
                        <li><strong>Output Layer</strong>: y = W<sub>y</sub>h<sub>t</sub> + b<sub>y</sub></li>
                        <li><strong>Softmax</strong>: Convert logits to probabilities</li>
                        <li><strong>Argmax</strong>: Select highest probability index</li>
                        <li><strong>Decode</strong>: Map index back to vocabulary token</li>
                    </ol>
                '},
                {id: 'math', icon: 'fa-superscript', label: 'Math', content: '
                    <h4><i class="fa fa-superscript"></i> Vanilla RNN</h4>
                    <div class="math-formula-display">
                        <code>h<sub>t</sub> = tanh(W<sub>h</sub> h<sub>t-1</sub> + W<sub>x</sub> x<sub>t</sub> + b<sub>h</sub>)</code>
                    </div>
                    <div class="math-formula-display">
                        <code>y<sub>t</sub> = softmax(W<sub>y</sub> h<sub>t</sub> + b<sub>y</sub>)</code>
                    </div>
                    <p class="formula-note">
                        W<sub>h</sub> maps hidden-to-hidden, W<sub>x</sub> maps input-to-hidden,
                        W<sub>y</sub> maps hidden-to-output over the vocabulary.
                    </p>
                    <h4><i class="fa fa-bar-chart"></i> Softmax</h4>
                    <div class="math-formula-display">
                        <code>softmax(z<sub>i</sub>) = e<sup>z<sub>i</sub></sup> / &Sigma;<sub>j</sub> e<sup>z<sub>j</sub></sup></code>
                    </div>
                    <p class="formula-note">
                        Converts raw logits into a probability distribution over the vocabulary.
                    </p>
                '}
            ]
        ) }}

        {{ metricsPanel(
            title='Pipeline Metrics',
            icon='fa-bar-chart',
            metrics=[
                {icon: 'fa-cog', label: 'Phase', id: 'metric-phase', default: 'Idle'},
                {icon: 'fa-clock-o', label: 'Timestep', id: 'metric-timestep', default: '0 / 0'},
                {icon: 'fa-book', label: 'Vocab Size', id: 'metric-vocab-size', default: '-'},
                {icon: 'fa-arrows-h', label: 'Hidden Dim', id: 'metric-hidden-dim', default: '8'},
                {icon: 'fa-bullseye', label: 'Predicted', id: 'metric-predicted', default: '-'},
                {icon: 'fa-info-circle', label: 'Status', id: 'metric-status', default: 'Ready'}
            ]
        ) }}
    </div>
</div>
