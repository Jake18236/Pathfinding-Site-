title: Backpropagation Visualizer
icon: fa-retweet
navigation:
  - name: "Home"
    link: "index.html"
    icon: "fa-home"
permalink: "backpropagation.html"
extraScript: "static/js/backpropagation.js"
tags: visualization
cardTitle: "Backpropagation"
cardIcon: fa-retweet
cardDescription: "Step through the backpropagation algorithm. Watch gradients flow backward through a neural network layer by layer."
cardTags:
  - Deep Learning
  - Training
cardHaystack: "backpropagation backprop gradient chain rule neural network training loss vanishing gradient"
