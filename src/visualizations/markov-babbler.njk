{% from "components/metrics-panel.njk" import metricsPanel %}
{% from "components/info-tabs.njk" import infoTabs %}
{% from "components/legend.njk" import legend %}

<link rel="stylesheet" href="static/css/markov-babbler.css">

<div class="row" id="main-content">
    {% include "components/share-button.njk" %}
    <!-- Left Column: Context Graph + Generated Text + Controls -->
    <div class="col-md-7">
        <!-- Context Graph Panel -->
        <div class="panel panel-default">
            <div class="panel-heading">
                <div class="panel-heading-content">
                    <span class="panel-title-text"><i class="fa fa-commenting"></i> Context Graph</span>
                    <span class="viz-badge babbler-context-badge" id="context-badge">ready</span>
                </div>
            </div>
            <div class="panel-body canvas-panel-body">
                <div class="canvas-wrapper">
                    <canvas id="babbler-canvas" width="560" height="380"></canvas>
                </div>
            </div>
            <div class="panel-footer legend-footer">
                {{ legend(
                    items=[
                        {class: 'babbler-context-node', label: 'Context'},
                        {class: 'babbler-candidate-node', label: 'Candidate'},
                        {class: 'babbler-selected-node', label: 'Selected'},
                        {class: 'babbler-connection-line', label: 'Probability', type: 'line'}
                    ]
                ) }}
            </div>
        </div>

        <!-- Generated Text Panel -->
        <div class="panel panel-default">
            <div class="panel-heading">
                <div class="panel-heading-content">
                    <span class="panel-title-text"><i class="fa fa-file-text-o"></i> Generated Text</span>
                    <span class="viz-badge babbler-word-count" id="word-count-badge">0 words</span>
                </div>
            </div>
            <div class="panel-body compact-panel">
                <div id="generated-text-display" class="generated-text-display">
                    <p class="text-muted text-center" style="font-size: 12px;">
                        Click "Generate" to create text from the Markov model.
                    </p>
                </div>
            </div>
        </div>

        <!-- Controls Panel -->
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-sliders"></i> Controls</h3>
            </div>
            <div class="panel-body compact-panel babbler-controls-panel">
                <div class="babbler-options-col">
                    <div class="option-row">
                        <label>Corpus:</label>
                        <select id="corpus-select" class="form-control input-sm">
                            <option value="nursery" selected>Nursery Rhymes</option>
                            <option value="shakespeare">Shakespeare Sonnets</option>
                            <option value="tech">Tech Documentation</option>
                            <option value="stories">Simple Stories</option>
                            <option value="scifi">Science Fiction</option>
                            <option value="custom">Custom Text</option>
                        </select>
                    </div>
                    <div id="custom-corpus-section" class="custom-corpus-section" style="display: none;">
                        <textarea id="custom-corpus-input" class="form-control" rows="3"
                            placeholder="Paste your own text here (at least 50 words recommended)..."></textarea>
                        <button id="btn-build-custom" class="btn btn-xs btn-default" style="margin-top: 4px;">
                            <i class="fa fa-wrench"></i> Build Model
                        </button>
                    </div>
                    <div class="option-row">
                        <label>N-gram Order:</label>
                        <div class="stepper-control">
                            <button id="ngram-order-minus" class="btn btn-xs btn-default" title="Decrease order">&#8722;</button>
                            <input type="text" id="ngram-order-value" class="stepper-input" value="2" readonly>
                            <button id="ngram-order-plus" class="btn btn-xs btn-default" title="Increase order">+</button>
                        </div>
                    </div>
                    <div class="option-row">
                        <label>Seed Word:</label>
                        <select id="seed-select" class="form-control input-sm">
                            <option value="__random__">(Random)</option>
                        </select>
                    </div>
                    <div class="option-row">
                        <label>Max Words:</label>
                        <div class="stepper-control">
                            <button id="max-words-minus" class="btn btn-xs btn-default" title="Decrease max words">&#8722;</button>
                            <input type="text" id="max-words-value" class="stepper-input" value="50" readonly style="width: 42px;">
                            <button id="max-words-plus" class="btn btn-xs btn-default" title="Increase max words">+</button>
                        </div>
                    </div>
                </div>
                <div class="babbler-playback-col">
                    <div class="btn-toolbar" role="toolbar">
                        <button id="btn-generate" class="btn btn-sm btn-success" title="Generate text">
                            <i class="fa fa-play"></i> Generate
                        </button>
                        <button id="btn-step" class="btn btn-sm btn-info" title="Generate one word">
                            <i class="fa fa-step-forward"></i> Step
                        </button>
                        <button id="btn-reset" class="btn btn-sm btn-danger" title="Reset">
                            <i class="fa fa-refresh"></i> Reset
                        </button>
                    </div>
                    <div class="speed-control">
                        <i class="fa fa-tachometer"></i>
