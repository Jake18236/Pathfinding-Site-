---
layout: base.njk
title: Perceptron Learning Visualizer
icon: fa-bullseye
navigation:
  - name: "Home"
    link: "index.html"
    icon: "fa-home"
permalink: "perceptron.html"
extraScript: "static/js/perceptron.js"
tags: visualization
cardTitle: "Perceptron Learning"
cardIcon: fa-bullseye
cardDescription: "Watch a perceptron learn a linear decision boundary step-by-step. Explore convergence and failure on non-separable data."
cardTags:
  - Classification
  - Linear Models
cardHaystack: "perceptron linear classifier learning rule decision boundary weights bias convergence non-separable"
cardOrder: 9
cardImage: static/img/vis_cards/perceptron.png
---

{% from "components/legend.njk" import legend %}
{% from "components/info-tabs.njk" import infoTabs %}
{% from "components/speed-control.njk" import speedControl %}

<link rel="stylesheet" href="static/css/perceptron.css">

<div class="row" id="main-content">
    {% include "components/share-button.njk" %}
    <!-- Left Column: Canvas + Controls -->
    <div class="col-md-7">
        <div class="panel panel-default">
            <div class="panel-heading">
                <div class="panel-heading-content perceptron-header">
                    <div class="header-left">
                        <select id="dataset-select" class="form-control input-sm">
                            <option value="linear" selected>Linear</option>
                            <option value="moons">Moons</option>
                            <option value="xor">XOR</option>
                            <option value="blobs">Blobs</option>
                        </select>
                    </div>
                    <div class="header-right">
                        <div class="btn-group btn-group-sm" role="group">
                            <button id="btn-play" class="btn btn-success" title="Play">
                                <i class="fa fa-play"></i>
                            </button>
                            <button id="btn-pause" class="btn btn-warning" title="Pause" disabled>
                                <i class="fa fa-pause"></i>
                            </button>
                            <button id="btn-step-back" class="btn btn-info" title="Step back" disabled>
                                <i class="fa fa-step-backward"></i>
                            </button>
                            <button id="btn-step-forward" class="btn btn-info" title="Step forward" disabled>
                                <i class="fa fa-step-forward"></i>
                            </button>
                            <button id="btn-reset" class="btn btn-danger" title="Reset">
                                <i class="fa fa-refresh"></i>
                            </button>
                        </div>
                        {{ speedControl(value='6') }}
                        <span id="playback-step" class="viz-badge">Epoch 0</span>
                    </div>
                </div>
            </div>
            <div class="panel-body canvas-panel-body">
                <div class="canvas-wrapper">
                    <canvas id="perceptron-canvas"></canvas>
                    <div id="click-overlay" class="click-overlay" style="display: none;">
                        <span>Press Play to train</span>
                    </div>
                </div>
            </div>
            <div class="panel-footer legend-footer">
                {{ legend(
                    items=[
                        {class: 'class-0', label: 'Class 0'},
                        {class: 'class-1', label: 'Class 1'},
                        {class: 'misclassified', label: 'Misclassified'},
                        {class: 'boundary-line', label: 'Boundary', type: 'line'},
                        {class: 'weight-vector', label: 'Weight Vector', type: 'line'},
                        {class: 'margin-line', label: 'Margin', type: 'line'}
                    ]
                ) }}
            </div>
        </div>
    </div>

    <!-- Right Column: Info + Metrics -->
    <div class="col-md-5">
        {{ infoTabs(
            tabs=[
                {id: 'about', icon: 'fa-info-circle', label: 'About', active: true, content: '
                    <h4><i class="fa fa-bullseye"></i> Perceptron</h4>
                    <p>
                        The perceptron is a linear classifier that learns a separating line by adjusting
                        weights after each mistake. It converges on linearly separable data, but will
                        keep oscillating on non-separable datasets.
                    </p>
                    <h4><i class="fa fa-mouse-pointer"></i> How to Use</h4>
                    <ul class="interaction-list">
                        <li><strong>Press Play</strong> to train step-by-step</li>
                        <li><strong>Adjust learning rate</strong> to change update size</li>
                        <li><strong>Switch datasets</strong> to see convergence vs. failure</li>
                        <li><strong>Toggle margin/vector</strong> for geometric intuition</li>
                    </ul>
                '},
                {id: 'algorithm', icon: 'fa-book', label: 'Algorithm', content: '
                    <h4><i class="fa fa-cogs"></i> Training Loop</h4>
                    <ol class="algorithm-steps">
                        <li>Compute activation <code>a = w·x + b</code></li>
                        <li>Predict <code>ŷ = sign(a)</code></li>
                        <li>If wrong, update <code>w ← w + η(y - ŷ)x</code></li>
                        <li>Redraw the boundary</li>
                    </ol>
                    <p class="note">
                        On non-separable data, mistakes never reach zero.
                    </p>
                '},
                {id: 'steps', icon: 'fa-list-ol', label: 'Step List', content: '
                    <h4><i class="fa fa-list-ol"></i> Current Step</h4>
                    <ol class="algo-step-list">
                        <li id="step-activation">Activation: compute <code>w·x + b</code></li>
                        <li id="step-prediction">Prediction: classify the sample</li>
                        <li id="step-update">Update: adjust weights if needed</li>
                        <li id="step-redraw">Redraw: update boundary and metrics</li>
                    </ol>
                '},
                {id: 'controls', icon: 'fa-sliders', label: 'Controls', content: '
                    <div class="perceptron-tab-controls">
                        <div class="option-row">
                            <label>Init:</label>
                            <select id="init-select" class="form-control input-sm">
                                <option value="zero">Zero</option>
                                <option value="random" selected>Random</option>
                            </select>
                        </div>
                        <div class="option-row">
                            <label>LR:</label>
                            <input type="range" id="lr-slider" min="0.001" max="1" step="0.001" value="0.005">
                            <span id="lr-value" class="range-value">0.005</span>
                        </div>
                        <div class="option-row">
                            <label>Epochs:</label>
                            <div class="stepper-control">
                                <button id="epochs-minus" class="btn btn-xs btn-default" title="Decrease Epochs">&#8722;</button>
                                <input type="text" id="epochs-value" class="stepper-input" value="50" readonly>
                                <button id="epochs-plus" class="btn btn-xs btn-default" title="Increase Epochs">+</button>
                            </div>
                        </div>
                        <div class="option-row checkbox-row">
                            <label class="checkbox-label"><input type="checkbox" id="shuffle-toggle" checked> Shuffle each epoch</label>
                        </div>
                        <hr class="controls-divider">
                        <div class="option-row checkbox-row">
                            <label class="checkbox-label"><input type="checkbox" id="show-boundary" checked> Show boundary</label>
                        </div>
                        <div class="option-row checkbox-row">
                            <label class="checkbox-label"><input type="checkbox" id="show-vector" checked> Show weight vector</label>
                        </div>
                        <div class="option-row checkbox-row">
                            <label class="checkbox-label"><input type="checkbox" id="show-margin"> Show margin</label>
                        </div>
                    </div>
                '},
                {id: 'math', icon: 'fa-superscript', label: 'Math', content: '
                    <h4><i class="fa fa-superscript"></i> Decision Boundary</h4>
                    <p>
                        The boundary is the line where <code>w·x + b = 0</code>. The weight vector <code>w</code>
                        is normal to the line. The margin is proportional to <code>1 / ||w||</code>.
                    </p>
                '},
                {id: 'metrics', icon: 'fa-bar-chart', label: 'Metrics', content: '
                    <table class="table table-condensed metrics-table">
                        <tbody>
                            <tr><td><i class="fa fa-repeat"></i> Epoch</td><td id="metric-epoch" class="text-right metric-value">0</td></tr>
                            <tr><td><i class="fa fa-step-forward"></i> Step</td><td id="metric-step" class="text-right metric-value">0</td></tr>
                            <tr><td><i class="fa fa-exclamation-triangle"></i> Mistakes</td><td id="metric-mistakes" class="text-right metric-value">0</td></tr>
                            <tr><td><i class="fa fa-check-circle"></i> Accuracy</td><td id="metric-accuracy" class="text-right metric-value">0%</td></tr>
                            <tr><td><i class="fa fa-sliders"></i> Weights</td><td id="metric-weights" class="text-right metric-value">[-, -]</td></tr>
                            <tr><td><i class="fa fa-dot-circle-o"></i> Bias</td><td id="metric-bias" class="text-right metric-value">0.00</td></tr>
                            <tr><td><i class="fa fa-info-circle"></i> Status</td><td id="metric-status" class="text-right metric-value">Ready</td></tr>
                        </tbody>
                    </table>
                    <div class="sample-metrics">
                        <div><span class="sample-label">Sample:</span> <span id="metric-sample">-</span></div>
                        <div><span class="sample-label">Activation:</span> <span id="metric-activation">-</span></div>
                        <div><span class="sample-label">Prediction:</span> <span id="metric-prediction">-</span></div>
                        <div><span class="sample-label">Target:</span> <span id="metric-target">-</span></div>
                    </div>
                '}
            ]
        ) }}
    </div>
</div>
