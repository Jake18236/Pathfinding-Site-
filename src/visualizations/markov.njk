{% from "components/legend.njk" import legend %}
{% from "components/info-tabs.njk" import infoTabs %}
{% from "components/playback-controls.njk" import playbackControls %}

<link rel="stylesheet" href="static/css/markov.css">

<!-- Main Content: Chain Visualization (2/3) + Side Panel (1/3) -->
<div class="row" id="main-content">
    <!-- Markov Chain Graph -->
    <div class="col-md-8">
        <div class="panel panel-default markov-panel">
            <div class="panel-heading">
                <h3 class="panel-title">
                    <i class="fa fa-random"></i> Markov Chain
                    <span class="markov-header-controls pull-right">
                        <span id="markov-state-count" class="markov-state-count">0 states</span>
                        <select id="preset-select" class="markov-preset-select">
                            <option value="weather" selected>Weather Model</option>
                            <option value="pagerank">PageRank</option>
                            <option value="gambler">Gambler's Ruin</option>
                            <option value="drunkard">Drunkard Walk</option>
                        </select>
                    </span>
                </h3>
            </div>
            <div class="panel-body markov-panel-body">
                <div class="markov-canvas-wrapper">
                    <canvas id="markov-canvas" width="700" height="400"></canvas>
                </div>
            </div>
            <div class="panel-footer markov-footer">
                <div class="markov-footer-row">
                    <div class="markov-playback-section">
                        {{ playbackControls(
                            buttons=[
                                {id: 'btn-step-back', icon: 'step-backward', style: 'default', disabled: true, title: 'Step Back'},
                                {id: 'btn-play', icon: 'play', style: 'success', title: 'Start Simulation'},
                                {id: 'btn-pause', icon: 'pause', style: 'warning', disabled: true, title: 'Pause'},
                                {id: 'btn-step-forward', icon: 'step-forward', style: 'default', disabled: true, title: 'Step Forward'},
                                {id: 'btn-reset', icon: 'refresh', style: 'danger', title: 'Reset'}
                            ],
                            speedSlider=true
                        ) }}
                    </div>
                    <div class="markov-step-section">
                        <span id="step-display" class="step-display">Step: 0 / 0</span>
                        <div class="markov-steps-input">
                            <label for="num-steps">Steps:</label>
                            <input type="number" id="num-steps" value="50" min="10" max="500" step="10">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Distribution Histogram -->
        <div class="panel panel-default markov-histogram-panel">
            <div class="panel-heading">
                <h3 class="panel-title">
                    <i class="fa fa-bar-chart"></i> Distribution
                    <span class="markov-convergence-section pull-right">
                        <span id="convergence-indicator" class="convergence-indicator"></span>
                    </span>
                </h3>
            </div>
            <div class="panel-body">
                <div id="histogram-container" class="histogram-container">
                    <canvas id="histogram-canvas" width="700" height="150"></canvas>
                </div>
                <div class="histogram-legend">
                    <span class="histogram-legend-item">
                        <span class="legend-color empirical"></span> Empirical (visit frequency)
                    </span>
                    <span class="histogram-legend-item">
                        <span class="legend-color stationary"></span> Stationary (theoretical)
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Side Panel -->
    <div class="col-md-4">
        {{ infoTabs(
            tabs=[
                {id: 'about', icon: 'fa-info-circle', label: 'About', active: true, content: '
<h4>Markov Chains</h4>
<p>A <strong>Markov chain</strong> is a stochastic process where the probability of transitioning to any state depends only on the current state (memoryless property).</p>

<h5>How to Use</h5>
<ol>
    <li><strong>Select a preset:</strong> Choose from different example chains</li>
    <li><strong>Click Play:</strong> Watch the random walk simulation</li>
    <li><strong>Observe convergence:</strong> See how visit frequencies approach the stationary distribution</li>
</ol>

<h5>Key Concepts</h5>
<ul>
    <li><strong>Transition Probability:</strong> P(next state | current state)</li>
    <li><strong>Stationary Distribution:</strong> Long-run proportion of time in each state</li>
    <li><strong>Ergodic:</strong> Chain that converges to unique stationary distribution</li>
</ul>
                '},
                {id: 'matrix', icon: 'fa-table', label: 'Matrix', content: '
<h4>Transition Matrix</h4>
<p>The transition matrix P where P[i,j] = probability of going from state i to state j.</p>
<div id="matrix-container" class="matrix-container">
    <p class="text-muted">Select a preset to see the transition matrix.</p>
</div>

<div id="ergodic-status" class="ergodic-status">
</div>
                '},
                {id: 'examples', icon: 'fa-lightbulb', label: 'Try It', content: '
<h4>Things to Try</h4>

<h5>Weather Model</h5>
<p>Simple 2-state model: Sunny and Rainy days.</p>
<ul>
    <li>Watch how quickly it converges to ~67% Sunny, ~33% Rainy</li>
    <li>Notice the self-loops (staying in same state)</li>
</ul>

<h5>PageRank</h5>
<p>4-page web graph simulating random web surfer.</p>
<ul>
    <li>Pages with more incoming links get higher visit frequency</li>
    <li>This is how Google ranks web pages!</li>
</ul>

<h5>Gambler\'s Ruin</h5>
<p>Random walk with absorbing states at $0 and $3.</p>
<ul>
    <li>Notice: once you hit $0 or $3, you stay there forever</li>
    <li>These are "absorbing states"</li>
</ul>

<h5>Drunkard Walk</h5>
<p>Symmetric random walk on a line.</p>
<ul>
    <li>Equal probability of moving left or right</li>
    <li>Converges to uniform distribution</li>
</ul>
                '}
            ]
        ) }}

        <!-- Status Panel -->
        <div class="panel panel-default markov-status-panel">
            <div class="panel-heading">
                <h3 class="panel-title">
                    <i class="fa fa-info"></i> Status
                </h3>
            </div>
            <div class="panel-body">
                <div id="playback-status" class="playback-status">
                    Click <strong>Play</strong> to start the random walk simulation.
                </div>
            </div>
        </div>
    </div>
</div>
