---
layout: base.njk
title: Decision Tree Visualizer
icon: fa-sitemap
navigation:
  - name: "Home"
    link: "index.html"
    icon: "fa-home"
permalink: "dtree.html"
extraScript: "static/js/dtree.js"
tags: visualization
cardTitle: "Decision Tree"
cardIcon: fa-sitemap
cardDescription: "Build and visualize decision trees for classification. Watch how splits partition the feature space and explore tree structure."
cardTags:
  - Classification
  - ML
cardHaystack: "decision tree classification machine learning splits gini entropy information gain"
cardOrder: 4
cardImage: static/img/vis_cards/dtree.png
---

{% from "components/edit-toolbar.njk" import editToolbar %}
{% from "components/legend.njk" import legend %}
{% from "components/speed-control.njk" import speedControl %}

<link rel="stylesheet" href="static/css/dtree.css">

<!-- Main Content: Canvas (left) + Info (right) -->
<div class="row" id="main-content">
    {% include "components/share-button.njk" %}
    <!-- Left Column: Classification Canvas + Controls -->
    <div class="col-md-7">
        <div class="panel panel-default">
            <div class="panel-heading">
                <div class="panel-heading-content">
                    <span class="panel-title-text"><i class="fa fa-crosshairs"></i> Classification Space</span>
                    {{ editToolbar(
                        modes=[
                            {id: 'classify', icon: 'fa-crosshairs', label: 'Classify', title: 'Click to classify', active: true},
                            {id: 'add', icon: 'fa-plus', label: 'Add', title: 'Add training points'},
                            {id: 'delete', icon: 'fa-minus', label: 'Delete', title: 'Delete points'}
                        ],
                        classes=[
                            {id: '0', title: 'Class 1', active: true},
                            {id: '1', title: 'Class 2'},
                            {id: '2', title: 'Class 3'}
                        ]
                    ) }}
                </div>
            </div>
            <div class="panel-body canvas-panel-body">
                <div class="canvas-wrapper">
                    <canvas id="dtree-canvas" width="560" height="400"></canvas>
                    <canvas id="boundary-canvas" width="560" height="400"></canvas>
                </div>
            </div>
            <div class="panel-footer legend-footer">
                {{ legend(
                    items=[
                        {class: 'class-0', label: 'Class 1'},
                        {class: 'class-1', label: 'Class 2'},
                        {class: 'class-2', label: 'Class 3', id: 'legend-class-2'},
                        {class: 'query-point', label: 'Query'},
                        {class: 'split-line', label: 'Split', type: 'line'}
                    ]
                ) }}
            </div>
        </div>

        <!-- Controls Panel -->
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-sliders"></i> Controls</h3>
            </div>
            <div class="panel-body compact-panel dtree-controls-panel">
                <!-- Left: Dataset & Algorithm Options -->
                <div class="dtree-options-col">
                    <div class="dtree-option-group">
                        <div class="option-row">
                            <label>Dataset:</label>
                            <select id="dataset-select" class="form-control input-sm">
                                <option value="moons" selected>Moons</option>
                                <option value="circles">Circles</option>
                                <option value="blobs">Blobs</option>
                                <option value="linear">Linear</option>
                                <option value="xor">XOR</option>
                                <option value="spiral">Spiral</option>
                                <option value="custom">Custom</option>
                            </select>
                        </div>
                        <div class="option-row">
                            <label>Criterion:</label>
                            <select id="criterion-select" class="form-control input-sm">
                                <option value="gini">Gini Impurity</option>
                                <option value="entropy" selected>Entropy (Info Gain)</option>
                            </select>
                        </div>
                    </div>
                    <div class="dtree-option-group">
                        <div class="option-row">
                            <label>Max Depth:</label>
                            <div class="depth-stepper">
                                <button id="depth-minus" class="btn btn-xs btn-default" title="Decrease depth">−</button>
                                <input type="text" id="max-depth-value" class="depth-input" value="5" readonly>
                                <button id="depth-plus" class="btn btn-xs btn-default" title="Increase depth">+</button>
                            </div>
                        </div>
                        <label class="checkbox-label"><input type="checkbox" id="show-boundaries" checked> Boundaries</label>
                    </div>
                </div>
                <!-- Right: Tree Mode -->
                <div class="dtree-mode-col">
                    <div class="btn-group tree-mode-toggle" role="group">
                        <button type="button" class="btn btn-sm btn-default active" id="btn-auto-mode" title="Auto-build from data">
                            <i class="fa fa-magic"></i> Auto
                        </button>
                        <button type="button" class="btn btn-sm btn-default" id="btn-design-mode" title="Design tree manually">
                            <i class="fa fa-pencil"></i> Design
                        </button>
                    </div>
                    <div class="tree-action-buttons">
                        <button id="btn-rebuild-tree" class="btn btn-sm btn-default" title="Rebuild tree">
                            <i class="fa fa-refresh"></i>
                        </button>
                        <button id="btn-clear-tree" class="btn btn-sm btn-danger" title="Clear tree" style="display: none;">
                            <i class="fa fa-trash"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Tabbed Info -->
    <div class="col-md-5">
        <!-- Tabbed Info Panel with Tree as first tab -->
        <div class="panel panel-default panel-full-height">
            <div class="panel-heading">
                <ul class="nav nav-tabs panel-tabs">
                    <li class="active"><a href="#tab-tree" data-toggle="tab"><i class="fa fa-sitemap"></i> Tree</a></li>
                    <li><a href="#tab-about" data-toggle="tab"><i class="fa fa-info-circle"></i> About</a></li>
                    <li><a href="#tab-algorithm" data-toggle="tab"><i class="fa fa-book"></i> Algorithm</a></li>
                    <li><a href="#tab-math" data-toggle="tab"><i class="fa fa-calculator"></i> Math</a></li>
                    <li><a href="#tab-path" data-toggle="tab"><i class="fa fa-route"></i> Path</a></li>
                </ul>
            </div>
            <div class="panel-body">
                <div class="tab-content">
                    <!-- Tree Tab -->
                    <div class="tab-pane active" id="tab-tree">
                        <div class="tree-tab-header">
                            <div class="tree-stats-inline">
                                <span>Depth: <strong id="stat-depth">0</strong></span>
                                <span>Leaves: <strong id="stat-leaves">0</strong></span>
                                <span>Nodes: <strong id="stat-nodes">0</strong></span>
                            </div>
                            <div class="tree-zoom-controls">
                                <button id="tree-zoom-in" class="btn btn-xs btn-default" title="Zoom in"><i class="fa fa-search-plus"></i></button>
                                <button id="tree-zoom-out" class="btn btn-xs btn-default" title="Zoom out"><i class="fa fa-search-minus"></i></button>
                                <button id="tree-zoom-fit" class="btn btn-xs btn-default" title="Fit to view"><i class="fa fa-compress"></i></button>
                            </div>
                        </div>
                        <div id="design-instructions" class="design-instructions" style="display: none;">
                            <i class="fa fa-info-circle"></i>
                            <span id="design-instruction-text">Click a <strong>leaf node</strong> to split it</span>
                        </div>
                        <div class="tree-wrapper" id="tree-wrapper">
                            <svg id="tree-svg" width="100%" height="450"></svg>
                        </div>
                        <div class="tree-controls-row">
                            <div class="tree-hint"><i class="fa fa-hand-paper-o"></i> Drag to pan, scroll to zoom</div>
                            <div class="animation-controls">
                                <label class="checkbox-label"><input type="checkbox" id="animate-classification" checked> Animate</label>
                                {{ speedControl(id='animation-speed', icon='fa-clock-o') }}
                            </div>
                        </div>
                    </div>

                    <!-- About Tab -->
                    <div class="tab-pane" id="tab-about">
                        <h4><i class="fa fa-sitemap"></i> What is a Decision Tree?</h4>
                        <p>
                            A <strong>Decision Tree</strong> is a flowchart-like classifier that makes decisions
                            by asking a series of questions about feature values.
                        </p>
                        <h4><i class="fa fa-mouse-pointer"></i> How to Use</h4>
                        <ul class="interaction-list">
                            <li><strong>Click</strong> anywhere to classify that point</li>
                            <li><strong>Watch</strong> the decision path highlight in the Tree tab</li>
                            <li><strong>Adjust depth</strong> to control tree complexity</li>
                            <li><strong>Design mode</strong> to build your own tree manually</li>
                        </ul>
                    </div>

                    <!-- Algorithm Tab -->
                    <div class="tab-pane" id="tab-algorithm">
                        <h4><i class="fa fa-cogs"></i> Building the Tree</h4>
                        <ol class="algorithm-steps">
                            <li>Start with all samples at root</li>
                            <li>Find best feature and threshold to split</li>
                            <li>Create child nodes for each split</li>
                            <li>Recurse until stopping criteria met</li>
                        </ol>
                        <h4><i class="fa fa-calculator"></i> Split Criteria</h4>
                        <p><strong>Gini:</strong> <code>G = 1 - Σ(pᵢ)²</code></p>
                        <p><strong>Entropy:</strong> <code>H = -Σ pᵢ log₂(pᵢ)</code></p>
                    </div>

                    <!-- Math Tab -->
                    <div class="tab-pane" id="tab-math">
                        <div class="math-tab-content">
                            <div id="math-empty" class="list-empty">
                                Click a split line on the canvas to see calculations
                            </div>
                            <div id="math-details" style="display: none;">
                                <div class="math-section math-header-section">
                                    <div class="math-node-title">
                                        <span id="math-node-label">Node</span>
                                        <span id="math-criterion-badge" class="badge">Gini</span>
                                    </div>
                                    <div class="math-split-condition">
                                        <code id="math-split-text">X ≤ 0.50</code>
                                    </div>
                                </div>

                                <div class="math-section math-parent-section">
                                    <div class="math-section-title math-parent-title">● Parent Node</div>
                                    <div class="math-stats">
                                        <span class="math-stat">n = <strong id="math-parent-n">0</strong></span>
                                        <span class="math-stat">Classes: <span id="math-parent-classes">{}</span></span>
                                    </div>
                                    <div class="math-formula">
                                        <span id="math-parent-formula"></span>
                                        <span class="math-result">= <strong id="math-parent-impurity">0</strong></span>
                                    </div>
                                </div>

                                <div id="math-left-section" class="math-section math-child-section math-region-section">
                                    <div class="math-section-title math-left-title">
                                        <span id="math-left-label">Left Region</span> <small id="math-left-condition"></small>
                                    </div>
                                    <div class="math-stats">
                                        <span class="math-stat">n = <strong id="math-left-n">0</strong></span>
                                        <span class="math-stat">Classes: <span id="math-left-classes">{}</span></span>
                                    </div>
                                    <div class="math-formula">
                                        <span id="math-left-formula"></span>
                                        <span class="math-result">= <strong id="math-left-impurity">0</strong></span>
                                    </div>
                                </div>

                                <div id="math-right-section" class="math-section math-child-section math-region-section">
                                    <div class="math-section-title math-right-title">
                                        <span id="math-right-label">Right Region</span> <small id="math-right-condition"></small>
                                    </div>
                                    <div class="math-stats">
                                        <span class="math-stat">n = <strong id="math-right-n">0</strong></span>
                                        <span class="math-stat">Classes: <span id="math-right-classes">{}</span></span>
                                    </div>
                                    <div class="math-formula">
                                        <span id="math-right-formula"></span>
                                        <span class="math-result">= <strong id="math-right-impurity">0</strong></span>
                                    </div>
                                </div>

                                <div class="math-section math-gain-section">
                                    <div class="math-section-title">Information Gain</div>
                                    <div class="math-formula math-gain-formula">
                                        <div id="math-gain-breakdown"></div>
                                        <div class="math-gain-result">
                                            Gain = <strong id="math-gain-value">0</strong>
                                        </div>
                                    </div>
                                </div>

                                <div class="math-reset-section">
                                    <button id="math-reset-btn" class="btn btn-sm btn-default">
                                        <i class="fa fa-undo"></i> Reset View
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Path Tab -->
                    <div class="tab-pane" id="tab-path">
                        <div class="path-header">
                            <span>Decision Path</span>
                            <span id="path-length" class="badge">0</span>
                        </div>
                        <div id="path-list" class="path-list">
                            <div class="list-empty">Click to classify a point</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Design Mode Split Dialog -->
<div id="split-dialog" class="split-dialog" style="display: none;">
    <div class="split-dialog-content">
        <div class="split-dialog-header">
            <span><i class="fa fa-code-fork"></i> Create Split</span>
            <button id="btn-close-split-dialog" class="btn btn-xs btn-default"><i class="fa fa-times"></i></button>
        </div>
        <div class="split-dialog-body">
            <div class="split-option-row">
                <label>Feature:</label>
                <div class="btn-group" role="group">
                    <button type="button" class="btn btn-sm btn-default active" data-feature="x">X (horizontal)</button>
                    <button type="button" class="btn btn-sm btn-default" data-feature="y">Y (vertical)</button>
                </div>
            </div>
            <div class="split-option-row">
                <label>Threshold: <span id="threshold-value">0.50</span></label>
                <input type="range" id="threshold-slider" min="0" max="100" value="50">
            </div>
            <div class="split-preview">
                <span id="split-preview-text">x ≤ 0.50</span>
            </div>
        </div>
        <div class="split-dialog-footer">
            <button id="btn-cancel-split" class="btn btn-sm btn-default">Cancel</button>
            <button id="btn-apply-split" class="btn btn-sm btn-success"><i class="fa fa-check"></i> Apply Split</button>
        </div>
    </div>
</div>
