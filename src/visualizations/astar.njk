---
layout: base.njk
title: A* Pathfinding Visualizer
icon: fa-route
navigation:
  - name: "Home"
    link: "index.html"
    icon: "fa-home"
permalink: "astar.html"
extraScript: "static/js/astar.js"
tags: visualization
cardTitle: "A* Pathfinding"
cardIcon: fa-route
cardDescription: "Visualize the A* search algorithm finding optimal paths through grids. Compare heuristics like Manhattan, Euclidean, and Dijkstra."
cardTags:
  - Search
  - Heuristics
cardHaystack: "a* pathfinding search heuristics manhattan euclidean dijkstra grid optimal paths"
cardOrder: 1
cardImage: static/img/vis_cards/astar.png
---

{% from "components/info-tabs.njk" import infoTabs %}
{% from "components/legend.njk" import legend %}
{% from "components/algorithm-options.njk" import algorithmOptions %}
{% from "components/metrics-panel.njk" import metricsPanel %}

<link rel="stylesheet" href="static/css/astar.css">

<!-- Main Content: Grid (left) + Info Tabs (right) -->
<div class="row" id="main-content">
    {% include "components/share-button.njk" %}
    <!-- Left Column: Pathfinding Grid + Options/Metrics -->
    <div class="col-md-7">
        <div class="panel panel-default">
            <div class="panel-body grid-panel-body">
                <!-- Combined Toolbar: Sample select, Edit buttons, Playback controls (custom - too integrated) -->
                <div class="unified-toolbar">
                    <div class="toolbar-left">
                        <div class="sample-select-wrapper">
                            <select id="sample-select" class="form-control input-sm">
                                <optgroup label="Grid Maps">
                                    <option value="easy" selected>Grid: Easy</option>
                                    <option value="medium">Grid: Medium</option>
                                    <option value="hard">Grid: Hard</option>
                                    <option value="maze">Grid: Maze</option>
                                    <option value="nosolution">Grid: No Solution</option>
                                    <option value="custom">Grid: Custom</option>
                                </optgroup>
                                <optgroup label="Direct Graphs">
                                    <option value="graph-simple">Graph: Simple</option>
                                    <option value="graph-trap">Graph: Trap</option>
                                    <option value="graph-custom">Graph: Custom</option>
                                </optgroup>
                            </select>
                        </div>
                        <!-- Grid edit buttons -->
                        <div class="btn-group edit-mode-buttons grid-controls" role="group" id="edit-mode-buttons">
                            <button type="button" class="btn btn-sm btn-default" data-mode="wall" title="Draw walls" disabled>
                                <i class="fa fa-square"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-default" data-mode="start" title="Place start" disabled>
                                <i class="fa fa-play-circle"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-default" data-mode="goal" title="Place goal" disabled>
                                <i class="fa fa-flag-checkered"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-default" data-mode="erase" title="Erase cells" disabled>
                                <i class="fa fa-eraser"></i>
                            </button>
                        </div>
                        <button id="btn-clear-grid" class="btn btn-sm btn-danger grid-controls" title="Clear entire grid" disabled>
                            <i class="fa fa-trash"></i>
                        </button>
                        <!-- Graph edit buttons (hidden by default) -->
                        <div class="btn-group graph-edit-buttons graph-controls" role="group" style="display: none;">
                            <button type="button" class="btn btn-sm btn-default" data-mode="node" title="Add/edit node" disabled>
                                <i class="fa fa-circle-o"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-default" data-mode="edge" title="Add edge" disabled>
                                <i class="fa fa-long-arrow-right"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-default" data-mode="start" title="Set start" disabled>
                                <i class="fa fa-play-circle"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-default" data-mode="goal" title="Set goal" disabled>
                                <i class="fa fa-flag-checkered"></i>
                            </button>
                            <button type="button" class="btn btn-sm btn-default" data-mode="delete" title="Delete" disabled>
                                <i class="fa fa-eraser"></i>
                            </button>
                        </div>
                        <button id="btn-clear-graph" class="btn btn-sm btn-danger graph-controls" title="Clear graph" disabled style="display: none;">
                            <i class="fa fa-trash"></i>
                        </button>
                    </div>
                    <div class="toolbar-right">
                        <div class="btn-group playback-buttons" role="group">
                            <button id="btn-solve" class="btn btn-sm btn-success" title="Run A* algorithm">
                                <i class="fa fa-play"></i>
                            </button>
                            <button id="btn-pause" class="btn btn-sm btn-warning" title="Pause/Resume" disabled>
                                <i class="fa fa-pause"></i>
                            </button>
                            <button id="btn-step-back" class="btn btn-sm btn-info" title="Step backward" disabled>
                                <i class="fa fa-step-backward"></i>
                            </button>
                            <button id="btn-step" class="btn btn-sm btn-info" title="Step forward" disabled>
                                <i class="fa fa-step-forward"></i>
                            </button>
                            <button id="btn-reset" class="btn btn-sm btn-danger" title="Reset visualization">
                                <i class="fa fa-refresh"></i>
                            </button>
                        </div>
                        <div class="speed-control-inline">
                            <input type="range" id="speed-slider" min="1" max="10" value="9" title="Playback speed">
                        </div>
                    </div>
                </div>

                <div class="grid-wrapper">
                    <!-- Grid visualization -->
                    <div id="pathfinding-grid" class="pathfinding-grid">
                        <!-- Grid cells generated by JavaScript -->
                    </div>
                    <svg id="heuristic-overlay" class="heuristic-overlay">
                        <!-- Heuristic visualization lines drawn here -->
                    </svg>
                    <!-- Graph visualization (hidden by default) -->
                    <div id="graph-visualization" class="graph-visualization" style="display: none;">
                        <!-- SVG graph rendered by JavaScript -->
                    </div>
                </div>

                <!-- Graph heuristics table (hidden by default) -->
                <div id="graph-heuristics-panel" class="graph-heuristics-panel graph-controls" style="display: none;">
                    <span class="heuristics-title">Node Heuristics (h-values)</span>
                    <div id="graph-heuristics-table" class="heuristics-table">
                        <!-- Populated by JavaScript -->
                    </div>
                </div>

                <div class="grid-footer">
                    <!-- Grid legend -->
                    <div class="grid-controls">
                        {{ legend(
                            items=[
                                {class: 'legend-start', label: 'Start'},
                                {class: 'legend-goal', label: 'Goal'},
                                {class: 'legend-wall', label: 'Wall'},
                                {class: 'legend-open', label: 'Frontier'},
                                {class: 'legend-closed', label: 'Visited'},
                                {class: 'legend-path', label: 'Path'}
                            ],
                            className='grid-legend'
                        ) }}
                    </div>
                    <!-- Graph legend (hidden by default) -->
                    <div class="graph-controls" style="display: none;">
                        {{ legend(
                            items=[
                                {class: 'legend-start', label: 'Start'},
                                {class: 'legend-goal', label: 'Goal'},
                                {class: 'legend-open', label: 'Frontier'},
                                {class: 'legend-closed', label: 'Visited'},
                                {class: 'legend-path', label: 'Path'}
                            ],
                            className='grid-legend'
                        ) }}
                    </div>
                    <div class="playback-status">
                        <span id="playback-step">Step: 0 / 0</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Algorithm Options + Metrics (side by side under grid) -->
        <div class="row options-metrics-row">
            <div class="col-sm-7">
                {{ algorithmOptions(
                    title='Algorithm Options',
                    options=[
                        {type: 'select', label: 'Algorithm', id: 'heuristic-select', options: [
                            {value: 'manhattan', text: 'A* Manhattan', selected: true},
                            {value: 'euclidean', text: 'A* Euclidean'},
                            {value: 'chebyshev', text: 'A* Chebyshev'},
                            {value: 'dijkstra', text: 'Dijkstra (h=0)'},
                            {value: 'bfs', text: 'BFS'},
                            {value: 'dfs', text: 'DFS'}
                        ]},
                        {type: 'select', label: 'Movement', id: 'movement-mode', class: 'grid-controls', options: [
                            {value: 'grid', text: '4-Dir', selected: true},
                            {value: 'free', text: '8-Dir'}
                        ]},
                        {type: 'select', label: 'Tie-break', id: 'tiebreaker-select', options: [
                            {value: 'none', text: 'None'},
                            {value: 'highg', text: 'High g', selected: true},
                            {value: 'lowg', text: 'Low g'}
                        ]},
                        {type: 'slider', label: 'Weight', id: 'heuristic-weight', min: 1, max: 3, step: 0.1, value: 1, valueId: 'weight-value'},
                        {type: 'checkbox', label: 'Show f/g/h', id: 'show-values'}
                    ]
                ) }}
            </div>
            <div class="col-sm-5">
                {{ metricsPanel(
                    title='Metrics',
                    layout='grid',
                    rows=[
                        [{icon: 'fa-expand', label: 'Explored', id: 'metric-expanded', default: '0'},
                         {icon: 'fa-plus-square', label: 'Discovered', id: 'metric-generated', default: '0'}],
                        [{icon: 'fa-road', label: 'Path Len', id: 'metric-path-length'},
                         {icon: 'fa-calculator', label: 'Cost', id: 'metric-path-cost'}],
                        [{icon: 'fa-clock-o', label: 'Time', id: 'metric-time', default: '0.00ms', colspan: 3}]
                    ]
                ) }}
            </div>
        </div>
    </div>

    <!-- Right Column: Info Tabs -->
    <div class="col-md-5">
        {{ infoTabs(
            tabs=[
                {id: 'about', icon: 'fa-info-circle', label: 'About', active: true, content: '
                    <h4><i class=\"fa fa-route\"></i> What is A*?</h4>
                    <p>
                        <strong>A*</strong> (A-star) is the most popular pathfinding algorithm. It combines
                        Dijkstra\"s guaranteed shortest path with heuristic guidance toward the goal.
                    </p>
                    <h4><i class=\"fa fa-calculator\"></i> The Formula</h4>
                    <p>
                        A* evaluates nodes using: <code>f(n) = g(n) + h(n)</code>
                    </p>
                    <ul class=\"formula-list\">
                        <li><strong>g(n)</strong> - Actual cost from start to node n</li>
                        <li><strong>h(n)</strong> - Estimated cost from n to goal (heuristic)</li>
                        <li><strong>f(n)</strong> - Total estimated cost through n</li>
                    </ul>
                    <h4><i class=\"fa fa-compass\"></i> Heuristics & Movement</h4>
                    <p><strong>Grid (4-dir):</strong> Use <em>Manhattan</em> - it exactly matches the movement cost.</p>
                    <p><strong>Free Space (8-dir):</strong> Use <em>Euclidean</em> or <em>Chebyshev</em> - they match diagonal movement costs.</p>
                    <ul class=\"algorithm-list\">
                        <li><strong>Manhattan</strong> - |dx| + |dy|</li>
                        <li><strong>Euclidean</strong> - sqrt(dx² + dy²)</li>
                        <li><strong>Chebyshev</strong> - max(|dx|, |dy|)</li>
                        <li><strong>Dijkstra</strong> - h=0 (no heuristic)</li>
                    </ul>
                    <h4><i class=\"fa fa-sitemap\"></i> Other Algorithms</h4>
                    <ul class=\"algorithm-list\">
                        <li><strong>BFS</strong> - Breadth-first search explores all nodes at depth d before d+1. Guarantees shortest path (by hop count).</li>
                        <li><strong>DFS</strong> - Depth-first search explores as deep as possible before backtracking. Fast but does not guarantee shortest path.</li>
                    </ul>
                '},
                {id: 'pseudocode', icon: 'fa-code', label: 'Code', content: '
                    <div class=\"pseudocode-container\">
                        <pre class=\"pseudocode\"><code><span class=\"line\" data-line=\"init\"><span class=\"keyword\">function</span> <span class=\"function\">A*</span>(start, goal):</span>
<span class=\"line\" data-line=\"init-open\">    openSet ← {start}</span>
<span class=\"line\" data-line=\"init-closed\">    closedSet ← {}</span>
<span class=\"line\" data-line=\"init-g\">    g[start] ← <span class=\"number\">0</span></span>
<span class=\"line\" data-line=\"init-f\">    f[start] ← h(start, goal)</span>
<span class=\"line\" data-line=\"while\">    <span class=\"keyword\">while</span> openSet <span class=\"keyword\">is not</span> empty:</span>
<span class=\"line\" data-line=\"select\">        current ← node in openSet with lowest f</span>
<span class=\"line\" data-line=\"goal-found\">        <span class=\"keyword\">if</span> current = goal:</span>
<span class=\"line\" data-line=\"return-path\">            <span class=\"keyword\">return</span> reconstructPath(current)</span>
<span class=\"line\" data-line=\"remove-open\">        openSet.remove(current)</span>
<span class=\"line\" data-line=\"add-closed\">        closedSet.add(current)</span>
<span class=\"line\" data-line=\"for-neighbor\">        <span class=\"keyword\">for each</span> neighbor <span class=\"keyword\">of</span> current:</span>
<span class=\"line\" data-line=\"skip-closed\">            <span class=\"keyword\">if</span> neighbor <span class=\"keyword\">in</span> closedSet: <span class=\"keyword\">continue</span></span>
<span class=\"line\" data-line=\"tentative-g\">            tentativeG ← g[current] + cost(current, neighbor)</span>
<span class=\"line\" data-line=\"if-better\">            <span class=\"keyword\">if</span> tentativeG &lt; g[neighbor]:</span>
<span class=\"line\" data-line=\"update-parent\">                parent[neighbor] ← current</span>
<span class=\"line\" data-line=\"update-g\">                g[neighbor] ← tentativeG</span>
<span class=\"line\" data-line=\"update-f\">                f[neighbor] ← g[neighbor] + h(neighbor, goal)</span>
<span class=\"line\" data-line=\"add-to-open\">                <span class=\"keyword\">if</span> neighbor <span class=\"keyword\">not in</span> openSet:</span>
<span class=\"line\" data-line=\"push-open\">                    openSet.add(neighbor)</span>
<span class=\"line\" data-line=\"no-path\">    <span class=\"keyword\">return</span> <span class=\"string\">\"no path found\"</span></span></code></pre>
                    </div>
                    <div class=\"pseudocode-legend\">
                        <span class=\"legend-active\"><i class=\"fa fa-arrow-right\"></i> Current step</span>
                    </div>
                '},
                {id: 'lists', icon: 'fa-list', label: 'Lists', content: '
                    <div class=\"lists-container\">
                        <div class=\"list-section\">
                            <h5><i class=\"fa fa-folder-open\"></i> Frontier <span id=\"open-count\" class=\"badge\">0</span></h5>
                            <div id=\"open-list\" class=\"node-list\">
                                <div class=\"list-empty\">No nodes yet</div>
                            </div>
                        </div>
                        <div class=\"list-section\">
                            <h5><i class=\"fa fa-folder\"></i> Visited <span id=\"closed-count\" class=\"badge\">0</span></h5>
                            <div id=\"closed-list\" class=\"node-list\">
                                <div class=\"list-empty\">No nodes yet</div>
                            </div>
                        </div>
                    </div>
                '},
                {id: 'log', icon: 'fa-terminal', label: 'Log', content: '
                    <div class=\"log-header\">
                        <button id=\"btn-clear-log\" class=\"btn btn-xs btn-default pull-right\">
                            <i class=\"fa fa-trash\"></i> Clear
                        </button>
                    </div>
                    <div id=\"execution-log\" class=\"execution-log\">
                        <div class=\"log-entry log-info\">
                            <span class=\"log-icon\"><i class=\"fa fa-info-circle\"></i></span>
                            <span class=\"log-message\">Select Custom to draw, then click Solve.</span>
                        </div>
                    </div>
                '},
                {id: 'compare', icon: 'fa-table', label: 'Compare', content: '
                    <div class=\"compare-controls\">
                        <button id=\"btn-run-comparison\" class=\"btn btn-sm btn-default\">
                            <i class=\"fa fa-refresh\"></i> Refresh
                        </button>
                    </div>
                    <div class=\"compare-table-container\">
                        <table id=\"comparison-table\" class=\"table table-bordered table-striped table-condensed\">
                            <thead>
                                <tr>
                                    <th>Heuristic</th>
                                    <th>Explored</th>
                                    <th>Discovered</th>
                                    <th>Path</th>
                                    <th>Cost</th>
                                    <th>Time</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                    <p class=\"compare-hint\">
                        <i class=\"fa fa-lightbulb-o\"></i> Click a row to visualize.
                    </p>
                '}
            ]
        ) }}
    </div>
</div>
