{% from "components/legend.njk" import legend %}
{% from "components/info-tabs.njk" import infoTabs %}
{% from "components/metrics-panel.njk" import metricsPanel %}

<link rel="stylesheet" href="static/css/transformer.css">

<div class="row" id="main-content">
    {% include "components/share-button.njk" %}
    <!-- Left Column: Heatmap + Controls -->
    <div class="col-md-7">
        <div class="panel panel-default">
            <div class="panel-heading">
                <div class="panel-heading-content">
                    <span class="panel-title-text"><i class="fa fa-th"></i> Attention Heatmap</span>
                    <div class="header-controls">
                        <div class="btn-group btn-group-sm head-toggle" role="group" id="head-tabs">
                            <!-- Head tabs filled dynamically -->
                        </div>
                        <span class="viz-badge head-badge" id="head-badge">Head 1</span>
                    </div>
                </div>
            </div>
            <div class="panel-body canvas-panel-body">
                <div class="canvas-wrapper">
                    <canvas id="attention-canvas" width="560" height="400"></canvas>
                </div>
            </div>
            <div class="panel-footer legend-footer">
                {{ legend(
                    items=[
                        {class: 'attn-low', label: 'Low Attention', type: 'color'},
                        {class: 'attn-mid', label: 'Medium', type: 'color'},
                        {class: 'attn-high', label: 'High Attention', type: 'color'}
                    ]
                ) }}
            </div>
        </div>

        <!-- Controls Panel -->
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-sliders"></i> Controls</h3>
            </div>
            <div class="panel-body compact-panel tf-controls-panel">
                <div class="tf-input-col">
                    <label class="control-label-sm">Input Sentence</label>
                    <input type="text" id="input-sentence" class="form-control tf-sentence-input"
                           value="The cat sat on the mat" placeholder="Enter a sentence...">
                </div>

                <div class="tf-options-col">
                    <div class="option-row">
                        <label>Heads:</label>
                        <div class="stepper-control">
                            <button class="btn btn-xs btn-default" id="btn-heads-dec"><i class="fa fa-minus"></i></button>
                            <input type="text" id="num-heads" class="stepper-input" value="4" readonly>
                            <button class="btn btn-xs btn-default" id="btn-heads-inc"><i class="fa fa-plus"></i></button>
                        </div>
                    </div>
                    <div class="option-row">
                        <label>Temperature:</label>
                        <input type="range" id="temperature-slider" min="0.1" max="5.0" step="0.1" value="1.0">
                        <span id="temperature-value" class="range-value">1.0</span>
                    </div>
                    <label class="checkbox-label">
                        <input type="checkbox" id="toggle-pe"> Show Positional Encoding
                    </label>
                </div>

                <div class="tf-actions-col">
                    <button id="btn-compute" class="btn btn-sm btn-success" title="Compute Attention">
                        <i class="fa fa-play"></i> Compute Attention
                    </button>
                    <button id="btn-reset" class="btn btn-sm btn-danger" title="Reset">
                        <i class="fa fa-refresh"></i> Reset
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Info + Metrics + Token Detail -->
    <div class="col-md-5">
        {% set aboutContent %}
                        <h4><i class="fa fa-eye"></i> Self-Attention</h4>
                        <p>
                            Self-attention allows each token in a sequence to look at every other
                            token and decide how much to focus on it. This is the core mechanism
                            in Transformer models like BERT and GPT.
                        </p>
                        <h4><i class="fa fa-key"></i> Key Insights</h4>
                        <ul class="insight-list">
                            <li><strong>Parallelizable</strong> &mdash; unlike RNNs, all positions are processed simultaneously</li>
                            <li><strong>Long-range dependencies</strong> &mdash; any token can attend to any other regardless of distance</li>
                            <li><strong>Multi-head</strong> &mdash; multiple attention heads capture different relationships</li>
                        </ul>
                        <h4><i class="fa fa-mouse-pointer"></i> How to Use</h4>
                        <ul class="interaction-list">
                            <li><strong>Enter a sentence</strong> and click Compute Attention</li>
                            <li><strong>Hover over cells</strong> to see attention weights for a token pair</li>
                            <li><strong>Switch heads</strong> to see different attention patterns</li>
                            <li><strong>Adjust temperature</strong> to sharpen or flatten attention</li>
                        </ul>
        {% endset %}

        {% set algorithmContent %}
                        <h4><i class="fa fa-cogs"></i> Q/K/V Computation</h4>
                        <ul class="algorithm-list">
                            <li>Each token embedding <code>x<sub>i</sub></code> is projected into three vectors:</li>
                            <li><strong>Query</strong>: <code>q<sub>i</sub> = W<sub>Q</sub> x<sub>i</sub></code></li>
                            <li><strong>Key</strong>: <code>k<sub>i</sub> = W<sub>K</sub> x<sub>i</sub></code></li>
                            <li><strong>Value</strong>: <code>v<sub>i</sub> = W<sub>V</sub> x<sub>i</sub></code></li>
                        </ul>

                        <h4><i class="fa fa-tasks"></i> Scaled Dot-Product Steps</h4>
                        <ol class="algorithm-list">
                            <li>Compute scores: <code>s<sub>ij</sub> = q<sub>i</sub> &middot; k<sub>j</sub></code></li>
                            <li>Scale: <code>s<sub>ij</sub> / &radic;d<sub>k</sub></code></li>
                            <li>Apply softmax row-wise to get weights</li>
                            <li>Weighted sum of values gives the output</li>
                        </ol>

                        <h4><i class="fa fa-copy"></i> Multi-Head Attention</h4>
                        <p class="formula-note">
                            Multiple heads run in parallel with different learned projections,
                            then their outputs are concatenated and projected back.
                        </p>
        {% endset %}

        {% set mathContent %}
                        <h4><i class="fa fa-superscript"></i> Attention Formula</h4>
                        <div class="math-formula-display">
                            <code>Attention(Q,K,V) = softmax(QK<sup>T</sup>/&radic;d<sub>k</sub>)V</code>
                        </div>
                        <p class="formula-note">
                            Where d<sub>k</sub> is the dimension of the key vectors.
                            Scaling prevents dot products from becoming too large.
                        </p>

                        <h4><i class="fa fa-bar-chart"></i> Softmax</h4>
                        <div class="math-formula-display">
                            <code>softmax(z<sub>i</sub>) = e<sup>z<sub>i</sub></sup> / &Sigma;<sub>j</sub> e<sup>z<sub>j</sub></sup></code>
                        </div>

                        <h4><i class="fa fa-wave-square"></i> Positional Encoding</h4>
                        <div class="math-formula-display">
                            <code>PE<sub>(pos,2i)</sub> = sin(pos / 10000<sup>2i/d</sup>)</code>
                        </div>
                        <div class="math-formula-display">
                            <code>PE<sub>(pos,2i+1)</sub> = cos(pos / 10000<sup>2i/d</sup>)</code>
                        </div>
                        <p class="formula-note">
                            Sinusoidal positional encodings inject word order information into
                            the model, since attention itself is permutation-invariant.
                        </p>
        {% endset %}

        {{ infoTabs(
            tabs=[
                {id: 'about', icon: 'fa-info-circle', label: 'About', active: true, content: aboutContent},
                {id: 'algorithm', icon: 'fa-cogs', label: 'Algorithm', content: algorithmContent},
                {id: 'math', icon: 'fa-superscript', label: 'Math', content: mathContent}
            ]
        ) }}

        {{ metricsPanel(
            title='Attention Metrics',
            icon='fa-bar-chart',
            metrics=[
                {icon: 'fa-font', label: 'Tokens', id: 'metric-tokens', default: '6'},
                {icon: 'fa-copy', label: 'Heads', id: 'metric-heads', default: '4'},
                {icon: 'fa-cube', label: 'Dimension', id: 'metric-dim', default: '64'},
                {icon: 'fa-arrow-up', label: 'Max Attention', id: 'metric-max-attn', default: '-'},
                {icon: 'fa-arrow-down', label: 'Min Attention', id: 'metric-min-attn', default: '-'},
                {icon: 'fa-info-circle', label: 'Status', id: 'metric-status', default: 'Ready'}
            ]
        ) }}

        <!-- Token Detail Panel -->
        <div class="panel panel-default" id="token-detail-panel">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-search"></i> Token Detail</h3>
            </div>
            <div class="panel-body compact-panel">
                <div id="token-detail-content">
                    <p class="no-data-message"><i class="fa fa-hand-pointer-o"></i><br>Hover over a cell in the heatmap to see attention details.</p>
                </div>
            </div>
        </div>
    </div>
</div>
