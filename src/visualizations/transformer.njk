{% from "components/legend.njk" import legend %}
{% from "components/info-tabs.njk" import infoTabs %}
{% from "components/stepper-control.njk" import stepperControl %}

<link rel="stylesheet" href="static/css/transformer.css">

<div class="row" id="main-content">
    {% include "components/share-button.njk" %}
    <!-- Left Column: Architecture Diagram -->
    <div class="col-md-7">
        <div class="panel panel-default">
            <div class="panel-heading">
                <div class="panel-heading-content">
                    <span class="panel-title-text"><i class="fa fa-eye"></i> Self-Attention</span>
                    <div class="header-controls">
                        <span class="viz-badge" id="tf-head-badge">4 Heads</span>
                        <span class="viz-badge" id="tf-dim-badge">d=64</span>
                    </div>
                </div>
            </div>
            <div class="panel-body compact-panel">
                <div class="tf-diagram" id="tf-diagram" aria-label="Attention Architecture Diagram">
                    <!-- JS populates: tokens → embedding → Q/K/V → head carousel → output -->
                </div>
            </div>
            <div class="panel-footer legend-footer">
                {{ legend(
                    items=[
                        {class: 'tf-embed-legend', label: 'Embedding'},
                        {class: 'tf-qkv-legend', label: 'Q / K / V'},
                        {class: 'tf-head-legend', label: 'Attn Head'},
                        {class: 'tf-output-legend', label: 'Output'},
                        {class: 'tf-flow-legend', label: 'Data Flow', type: 'dot'}
                    ]
                ) }}
            </div>
        </div>
    </div>

    <!-- Right Column: Info Tabs -->
    <div class="col-md-5">
        {{ infoTabs(
            tabs=[
                {id: 'about', icon: 'fa-info-circle', label: 'About', active: true, content: '
                    <h4><i class="fa fa-eye"></i> Self-Attention</h4>
                    <p>
                        Self-attention allows each token in a sequence to look at every other
                        token and decide how much to focus on it. This is the core mechanism
                        in Transformer models like BERT and GPT.
                    </p>
                    <p>
                        Each <strong>attention head</strong> learns different relationships &mdash;
                        one might track syntax, another might link pronouns to their referents.
                    </p>
                    <h4><i class="fa fa-mouse-pointer"></i> How to Use</h4>
                    <ul class="tf-how-list">
                        <li><strong>Navigate heads</strong> with the carousel &mdash; arrows, dots, or click a card</li>
                        <li><strong>Click a token</strong> to highlight what it attends to</li>
                        <li><strong>Expand blocks</strong> by clicking to see internal computations</li>
                        <li><strong>Adjust controls</strong> &mdash; heads, dimensions, temperature</li>
                    </ul>
                '},
                {id: 'algorithm', icon: 'fa-book', label: 'Algorithm', content: '
                    <h4><i class="fa fa-book"></i> Scaled Dot-Product Attention</h4>
                    <ol class="tf-algo-steps">
                        <li><strong>Embed:</strong> Look up each token in the embedding matrix, add positional encoding</li>
                        <li><strong>Project:</strong> Multiply by W<sub>Q</sub>, W<sub>K</sub>, W<sub>V</sub> to get Query, Key, Value</li>
                        <li><strong>Score:</strong> Compute q<sub>i</sub>&middot;k<sub>j</sub> for all token pairs</li>
                        <li><strong>Scale:</strong> Divide by &radic;d<sub>k</sub></li>
                        <li><strong>Softmax:</strong> Normalize each row &rarr; attention weights</li>
                        <li><strong>Attend:</strong> Weighted sum of Values = output</li>
                    </ol>
                    <h4><i class="fa fa-copy"></i> Multi-Head Attention</h4>
                    <p style="font-size:12px;">
                        Multiple heads run in parallel with different learned W<sub>Q</sub>, W<sub>K</sub>, W<sub>V</sub>.
                        Outputs are concatenated and projected through W<sub>O</sub>.
                    </p>
                    <div class="tf-formula">
                        Attention(Q,K,V) = softmax(QK<sup>T</sup> / &radic;d<sub>k</sub>)V
                    </div>
                '},
                {id: 'math', icon: 'fa-superscript', label: 'Math', content: '
                    <h4><i class="fa fa-superscript"></i> Live Computation</h4>
                    <div id="tf-math-panel">
                        <span style="font-size:12px; color:var(--viz-text-muted);">
                            Select a token and navigate heads to see live computations here.
                        </span>
                    </div>
                '},
                {id: 'controls', icon: 'fa-sliders', label: 'Controls', content: '
                    <div class="tf-controls-inner">
                        <div class="option-row">
                            <label>Example:</label>
                            <select id="tf-example-select" class="form-control input-sm">
                                <option value="0">The cat sat on the mat</option>
                                <option value="1">I like cute kitties and</option>
                                <option value="2">King is to queen as man</option>
                            </select>
                        </div>
                        <div class="option-row">
                            <label>Token:</label>
                            ' + stepperControl(id='tf-token-step', value='0', title='Token') + '
                        </div>
                        <div class="option-row">
                            <label>Heads:</label>
                            <select id="tf-num-heads" class="form-control input-sm">
                                <option value="1">1</option>
                                <option value="2">2</option>
                                <option value="4" selected>4</option>
                                <option value="8">8</option>
                            </select>
                        </div>
                        <div class="option-row">
                            <label>Model Dim:</label>
                            <select id="tf-model-dim" class="form-control input-sm">
                                <option value="32">32</option>
                                <option value="64" selected>64</option>
                                <option value="128">128</option>
                            </select>
                        </div>
                        <div class="option-row">
                            <label>Temp:</label>
                            <input type="range" id="tf-temperature" min="0.1" max="5.0" step="0.1" value="1.0">
                            <span id="tf-temp-value" class="stepper-value">1.0</span>
                        </div>
                        <div class="option-row">
                            <label class="checkbox-inline tf-pe-label">
                                <input type="checkbox" id="tf-use-pe" checked> Positional Enc.
                            </label>
                        </div>
                        <div class="tf-actions-row">
                            <button id="tf-btn-reset" class="btn btn-sm btn-danger">
                                <i class="fa fa-undo"></i> Reset
                            </button>
                        </div>
                    </div>
                '}
            ]
        ) }}
    </div>
</div>
