---
layout: base.njk
title: Embeddings Visualizer
icon: fa-braille
navigation:
  - name: "Home"
    link: "index.html"
    icon: "fa-home"
permalink: "mnist.html"
extraScript: "static/js/mnist.js"
tags: visualization
cardTitle: "Embeddings"
cardIcon: fa-braille
cardDescription: "Project MNIST and CIFAR-10 embeddings into 2D using PCA, t-SNE, and UMAP. Watch the embeddings evolve during training."
cardTags:
  - ML
  - Visualization
cardHaystack: "dimensionality reduction mnist cifar-10 pca t-sne umap cnn embeddings ml visualization machine learning"
cardOrder: 5
---

{% from "components/info-tabs.njk" import infoTabs %}
{% from "components/metrics-panel.njk" import metricsPanel %}
{% from "components/algorithm-options.njk" import algorithmOptions %}
{% from "components/controls-bar.njk" import controlsBar %}

<link rel="stylesheet" href="static/css/mnist.css">

{{ controlsBar(
    groups=[
        {type: 'button-group', label: 'Dataset', buttons: [
            {id: 'btn-mnist', label: 'MNIST', icon: 'fa-pencil', dataAttr: 'dataset', dataValue: 'mnist', active: true},
            {id: 'btn-cifar10', label: 'CIFAR-10', icon: 'fa-camera', dataAttr: 'dataset', dataValue: 'cifar10'}
        ]},
        {type: 'button-group', label: 'Data Source', buttons: [
            {id: 'btn-raw-pixels', label: 'Raw Pixels', icon: 'fa-th', dataAttr: 'source', dataValue: 'raw'},
            {id: 'btn-cnn-embeddings', label: 'CNN Embeddings', icon: 'fa-brain', dataAttr: 'source', dataValue: 'cnn', active: true}
        ]},
        {type: 'custom', content: '<span class="data-source-info" id="data-source-info"><i class="fa fa-info-circle"></i> 128-dim features from trained CNN</span>'}
    ],
    className='data-source-panel'
) }}

<!-- Training Timeline (only visible for CNN embeddings) -->
<div class="row">
    <div class="col-md-12">
        <div id="training-timeline" class="training-timeline panel panel-default">
            <div class="panel-body">
                <div class="timeline-header">
                    <span class="timeline-label"><i class="fa fa-graduation-cap"></i> Training Progress:</span>
                    <span class="epoch-display">Epoch <strong id="current-epoch">0</strong> / 10</span>
                    <span class="accuracy-display">Accuracy: <strong id="current-accuracy">-</strong></span>
                </div>
                <div class="timeline-controls">
                    <button id="btn-play-training" class="btn btn-sm btn-success" title="Play training animation">
                        <i class="fa fa-play"></i>
                    </button>
                    <button id="btn-pause-training" class="btn btn-sm btn-warning" title="Pause" style="display: none;">
                        <i class="fa fa-pause"></i>
                    </button>
                    <input type="range" id="epoch-slider" class="epoch-slider" min="0" max="6" value="0" step="1">
                    <div class="epoch-markers" id="epoch-markers">
                        <!-- Generated by JavaScript -->
                    </div>
                </div>
                <div class="timeline-hint">
                    <i class="fa fa-lightbulb-o"></i> Watch how embeddings organize as the network learns
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Main Content: Scatter Plot (left 65%) + Controls/Info (right 35%) -->
<div class="row" id="main-content">
    <!-- Left Column: Scatter Plot -->
    <div class="col-md-8">
        <div class="panel panel-default">
            <div class="panel-heading">
                <div class="panel-heading-content">
                    <div class="btn-group algorithm-tabs" role="group">
                        <button type="button" class="btn btn-sm btn-default" data-algorithm="pca">PCA</button>
                        <button type="button" class="btn btn-sm btn-default active" data-algorithm="tsne">t-SNE</button>
                        <button type="button" class="btn btn-sm btn-default" data-algorithm="umap">UMAP</button>
                    </div>
                </div>
            </div>
            <div class="panel-body scatter-panel-body">
                <div class="scatter-wrapper">
                    <canvas id="scatter-canvas" width="700" height="550"></canvas>
                    <div id="loading-overlay" class="loading-overlay">
                        <div class="spinner"></div>
                        <div class="loading-text">Loading data...</div>
                    </div>
                </div>
                <!-- Digit Tooltip -->
                <div id="digit-tooltip" class="digit-tooltip">
                    <canvas id="tooltip-canvas" width="84" height="84"></canvas>
                    <div class="tooltip-label">
                        <span class="tooltip-digit">Class: <strong id="tooltip-digit-value">-</strong></span>
                        <span class="tooltip-coords" id="tooltip-coords"></span>
                    </div>
                </div>
                <!-- Legend (generated by JavaScript) -->
                <div id="digit-legend" class="digit-legend">
                    <!-- Generated by JavaScript -->
                </div>
                <!-- Highlight Info -->
                <div id="highlight-info" class="highlight-info">
                    Highlighting class <span class="highlight-digit" id="highlight-digit-value">-</span>
                    <button id="btn-clear-highlight" class="btn btn-xs btn-default btn-clear-highlight">
                        <i class="fa fa-times"></i> Clear
                    </button>
                </div>
            </div>
        </div>

        {{ metricsPanel(
            title='Metrics',
            layout='grid',
            noHeader=true,
            rows=[
                [{icon: 'fa-database', label: 'Samples', id: 'metric-samples'},
                 {icon: 'fa-eye', label: 'Visible', id: 'metric-visible'}],
                [{icon: 'fa-bullseye', label: 'Highlighted', id: 'metric-highlighted'},
                 {icon: 'fa-mouse-pointer', label: 'Hovered', id: 'metric-hovered'}]
            ]
        ) }}
    </div>

    <!-- Right Column: Controls + Info -->
    <div class="col-md-4">
        {{ algorithmOptions(
            title='Display Options',
            icon='fa-sliders',
            options=[
                {type: 'slider', label: 'Point Size', id: 'point-size', min: 2, max: 12, value: 5, valueId: 'size-value'},
                {type: 'slider', label: 'Opacity', id: 'point-opacity', min: 20, max: 100, value: 70, valueId: 'opacity-value'},
                {type: 'checkbox', label: 'Show axes', id: 'show-axes', checked: true}
            ]
        ) }}

        <!-- Class Filter Panel (custom - filter grid) -->
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-filter"></i> Filter Classes</h3>
            </div>
            <div class="panel-body compact-panel">
                <div id="digit-filter-grid" class="digit-filter-grid">
                    <!-- Generated by JavaScript -->
                </div>
                <div class="filter-actions">
                    <button id="btn-show-all" class="btn btn-xs btn-default">Show All</button>
                    <button id="btn-hide-all" class="btn btn-xs btn-default">Hide All</button>
                </div>
            </div>
        </div>

        <!-- Tabbed Info Panel -->
        {{ infoTabs(
            tabs=[
                {id: 'about', icon: 'fa-info-circle', label: 'About', active: true, content: '
                    <h4><i class=\"fa fa-images\"></i> What is MNIST?</h4>
                    <p>
                        <strong>MNIST</strong> is a dataset of 70,000 handwritten digits (0-9),
                        each represented as a 28x28 grayscale image (784 pixels).
                    </p>
                    <h4><i class=\"fa fa-brain\"></i> Two Views</h4>
                    <p>
                        <strong>Raw Pixels:</strong> Project the 784-dim pixel values directly.<br>
                        <strong>CNN Embeddings:</strong> Project 128-dim features learned by a neural network.
                    </p>
                    <h4><i class=\"fa fa-graduation-cap\"></i> Training Evolution</h4>
                    <p>
                        In CNN mode, use the timeline to watch how embeddings evolve during training.
                        The network learns to separate classes as it trains!
                    </p>
                    <h4><i class=\"fa fa-mouse-pointer\"></i> Interactions</h4>
                    <ul class=\"interaction-list\">
                        <li><strong>Hover</strong> - View the original image</li>
                        <li><strong>Click</strong> - Highlight all points of that class</li>
                        <li><strong>Filter</strong> - Toggle classes on/off</li>
                        <li><strong>Play</strong> - Animate through training epochs</li>
                    </ul>
                '},
                {id: 'algorithms', icon: 'fa-cogs', label: 'Algorithms', content: '
                    <h4><i class=\"fa fa-project-diagram\"></i> PCA</h4>
                    <p>
                        <strong>Principal Component Analysis</strong> finds orthogonal axes
                        of maximum variance. Fast and deterministic, but linear - it cannot
                        capture non-linear relationships.
                    </p>
                    <h4><i class=\"fa fa-random\"></i> t-SNE</h4>
                    <p>
                        <strong>t-Distributed Stochastic Neighbor Embedding</strong> preserves
                        local neighborhoods using probability distributions. Non-linear and
                        excellent for visualization, but computationally expensive.
                    </p>
                    <h4><i class=\"fa fa-sitemap\"></i> UMAP</h4>
                    <p>
                        <strong>Uniform Manifold Approximation and Projection</strong> uses
                        topological methods. Faster than t-SNE and preserves both local and
                        global structure better.
                    </p>
                '},
                {id: 'compare', icon: 'fa-table', label: 'Compare', content: '
                    <table id=\"comparison-table\" class=\"table table-bordered table-striped table-condensed\">
                        <thead>
                            <tr>
                                <th>Algorithm</th>
                                <th>Type</th>
                                <th>Speed</th>
                                <th>Structure</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr data-algorithm=\"pca\">
                                <td>PCA</td>
                                <td>Linear</td>
                                <td>Fast</td>
                                <td>Global</td>
                            </tr>
                            <tr data-algorithm=\"tsne\" class=\"selected-row\">
                                <td>t-SNE</td>
                                <td>Non-linear</td>
                                <td>Slow</td>
                                <td>Local</td>
                            </tr>
                            <tr data-algorithm=\"umap\">
                                <td>UMAP</td>
                                <td>Non-linear</td>
                                <td>Medium</td>
                                <td>Both</td>
                            </tr>
                        </tbody>
                    </table>
                    <p class=\"compare-hint\">
                        <i class=\"fa fa-lightbulb-o\"></i> Click a row to switch to that algorithm.
                    </p>
                '}
            ]
        ) }}
    </div>
</div>
