---
layout: base.njk
title: A* Pathfinding Visualizer
icon: fa-route
navigation:
  - name: "Home"
    link: "index.html"
    icon: "fa-home"
permalink: "astar.html"
extraScript: "static/js/astar.js"
---

<link rel="stylesheet" href="static/css/astar.css">

<!-- Main Content: Grid (left 60%) + Controls/Info (right 40%) -->
<div class="row" id="main-content">
    <!-- Left Column: Pathfinding Grid -->
    <div class="col-md-7">
        <div class="panel panel-default">
            <div class="panel-heading">
                <div class="panel-heading-content">
                    <div class="btn-group sample-input-tabs" role="group">
                        <button type="button" class="btn btn-sm btn-default active" data-sample="easy" title="Simple direct path">Easy</button>
                        <button type="button" class="btn btn-sm btn-default" data-sample="medium" title="Moderate obstacles">Medium</button>
                        <button type="button" class="btn btn-sm btn-default" data-sample="hard" title="Complex maze">Hard</button>
                        <button type="button" class="btn btn-sm btn-default" data-sample="maze" title="Classic maze">Maze</button>
                        <button type="button" class="btn btn-sm btn-default" data-sample="nosolution" title="Blocked goal">No Solution</button>
                    </div>
                </div>
            </div>
            <div class="panel-body grid-panel-body">
                <div class="edit-toolbar">
                    <div class="btn-group edit-mode-buttons" role="group">
                        <button type="button" class="btn btn-sm btn-default active" data-mode="wall" title="Draw walls">
                            <i class="fa fa-square"></i> Wall
                        </button>
                        <button type="button" class="btn btn-sm btn-default" data-mode="start" title="Place start">
                            <i class="fa fa-play-circle"></i> Start
                        </button>
                        <button type="button" class="btn btn-sm btn-default" data-mode="goal" title="Place goal">
                            <i class="fa fa-flag-checkered"></i> Goal
                        </button>
                        <button type="button" class="btn btn-sm btn-default" data-mode="erase" title="Erase cells">
                            <i class="fa fa-eraser"></i> Erase
                        </button>
                    </div>
                    <button id="btn-clear-grid" class="btn btn-sm btn-danger" title="Clear entire grid">
                        <i class="fa fa-trash"></i> Clear
                    </button>
                </div>
                <div class="grid-wrapper">
                    <div id="pathfinding-grid" class="pathfinding-grid">
                        <!-- Grid cells generated by JavaScript -->
                    </div>
                    <svg id="heuristic-overlay" class="heuristic-overlay">
                        <!-- Heuristic visualization lines drawn here -->
                    </svg>
                </div>
                <div class="grid-legend">
                    <span class="legend-item"><span class="legend-color legend-start"></span> Start</span>
                    <span class="legend-item"><span class="legend-color legend-goal"></span> Goal</span>
                    <span class="legend-item"><span class="legend-color legend-wall"></span> Wall</span>
                    <span class="legend-item"><span class="legend-color legend-open"></span> Open</span>
                    <span class="legend-item"><span class="legend-color legend-closed"></span> Closed</span>
                    <span class="legend-item"><span class="legend-color legend-current"></span> Current</span>
                    <span class="legend-item"><span class="legend-color legend-path"></span> Path</span>
                    <span class="legend-item"><span class="legend-line legend-heuristic"></span> h(n)</span>
                </div>
            </div>
        </div>

        <!-- Playback Controls Panel (under grid) -->
        <div class="panel panel-default">
            <div class="panel-body playback-panel-body">
                <div class="playback-controls-row">
                    <div class="btn-toolbar playback-buttons" role="toolbar">
                        <button id="btn-solve" class="btn btn-success" title="Run A* algorithm">
                            <i class="fa fa-play"></i> Solve
                        </button>
                        <button id="btn-pause" class="btn btn-warning" title="Pause/Resume" disabled>
                            <i class="fa fa-pause"></i>
                        </button>
                        <button id="btn-step-back" class="btn btn-info" title="Step backward" disabled>
                            <i class="fa fa-step-backward"></i>
                        </button>
                        <button id="btn-step" class="btn btn-info" title="Step forward" disabled>
                            <i class="fa fa-step-forward"></i>
                        </button>
                        <button id="btn-reset" class="btn btn-danger" title="Reset visualization">
                            <i class="fa fa-refresh"></i>
                        </button>
                    </div>
                    <div class="playback-status">
                        <span id="playback-step">Step: 0 / 0</span>
                    </div>
                    <div class="speed-control-inline">
                        <label><i class="fa fa-tachometer"></i></label>
                        <input type="range" id="speed-slider" min="1" max="10" value="9">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Controls + Info Tabs -->
    <div class="col-md-5">
        <!-- Algorithm Options Panel -->
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-cogs"></i> Algorithm Options</h3>
            </div>
            <div class="panel-body compact-panel">
                <div class="option-row">
                    <label>Heuristic:</label>
                    <select id="heuristic-select" class="form-control input-sm">
                        <option value="manhattan" selected>Manhattan (default)</option>
                        <option value="euclidean">Euclidean</option>
                        <option value="chebyshev">Chebyshev</option>
                        <option value="dijkstra">Dijkstra (h=0)</option>
                    </select>
                </div>
                <div class="option-row">
                    <label>Movement:</label>
                    <select id="movement-mode" class="form-control input-sm">
                        <option value="grid" selected>4-Directional (Grid)</option>
                        <option value="free">8-Directional (Free Space)</option>
                    </select>
                </div>
                <div class="option-row">
                    <label class="checkbox-inline">
                        <input type="checkbox" id="show-values">
                        Show f/g/h values
                    </label>
                </div>
                <div class="option-row">
                    <label>Heuristic weight:</label>
                    <div class="weight-control">
                        <input type="range" id="heuristic-weight" min="1" max="3" step="0.1" value="1">
                        <span id="weight-value">1.0</span>
                    </div>
                </div>
                <div class="option-row">
                    <label>Tie-breaker:</label>
                    <select id="tiebreaker-select" class="form-control input-sm">
                        <option value="none">None</option>
                        <option value="highg" selected>Prefer higher g (default)</option>
                        <option value="lowg">Prefer lower g</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Metrics Panel -->
        <div class="panel panel-default">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-bar-chart"></i> Metrics</h3>
            </div>
            <div class="panel-body compact-panel">
                <table class="table table-condensed metrics-table">
                    <tbody>
                        <tr>
                            <td><i class="fa fa-expand"></i> Explored</td>
                            <td id="metric-expanded" class="text-right metric-value">0</td>
                            <td><i class="fa fa-plus-square"></i> Discovered</td>
                            <td id="metric-generated" class="text-right metric-value">0</td>
                        </tr>
                        <tr>
                            <td><i class="fa fa-road"></i> Path Length</td>
                            <td id="metric-path-length" class="text-right metric-value">-</td>
                            <td><i class="fa fa-calculator"></i> Path Cost</td>
                            <td id="metric-path-cost" class="text-right metric-value">-</td>
                        </tr>
                        <tr>
                            <td><i class="fa fa-clock-o"></i> Time</td>
                            <td id="metric-time" class="text-right metric-value" colspan="3">0.00ms</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Tabbed Info Panel -->
        <div class="panel panel-default">
            <div class="panel-heading">
                <div class="btn-group info-panel-tabs" role="group">
                    <button type="button" class="btn btn-sm btn-default active" data-tab="about">
                        <i class="fa fa-info-circle"></i> About
                    </button>
                    <button type="button" class="btn btn-sm btn-default" data-tab="lists">
                        <i class="fa fa-list"></i> Open/Closed
                    </button>
                    <button type="button" class="btn btn-sm btn-default" data-tab="log">
                        <i class="fa fa-terminal"></i> Log
                    </button>
                    <button type="button" class="btn btn-sm btn-default" data-tab="compare">
                        <i class="fa fa-table"></i> Compare
                    </button>
                </div>
            </div>
            <div class="panel-body info-panel-body">
                <!-- About Tab -->
                <div id="tab-about" class="info-tab-content active">
                    <h4><i class="fa fa-route"></i> What is A*?</h4>
                    <p>
                        <strong>A*</strong> (A-star) is the most popular pathfinding algorithm. It combines
                        Dijkstra's guaranteed shortest path with heuristic guidance toward the goal.
                    </p>
                    <h4><i class="fa fa-calculator"></i> The Formula</h4>
                    <p>
                        A* evaluates nodes using: <code>f(n) = g(n) + h(n)</code>
                    </p>
                    <ul class="formula-list">
                        <li><strong>g(n)</strong> - Actual cost from start to node n</li>
                        <li><strong>h(n)</strong> - Estimated cost from n to goal (heuristic)</li>
                        <li><strong>f(n)</strong> - Total estimated cost through n</li>
                    </ul>
                    <h4><i class="fa fa-compass"></i> Heuristics & Movement</h4>
                    <p><strong>Grid (4-dir):</strong> Use <em>Manhattan</em> - it exactly matches the movement cost.</p>
                    <p><strong>Free Space (8-dir):</strong> Use <em>Euclidean</em> or <em>Chebyshev</em> - they match diagonal movement costs.</p>
                    <ul class="algorithm-list">
                        <li><strong>Manhattan</strong> - |dx| + |dy|</li>
                        <li><strong>Euclidean</strong> - sqrt(dx^2 + dy^2)</li>
                        <li><strong>Chebyshev</strong> - max(|dx|, |dy|)</li>
                        <li><strong>Dijkstra</strong> - h=0 (no heuristic)</li>
                    </ul>
                    <p class="text-muted" style="font-size: 11px; margin-top: 8px;">
                        Mismatched heuristics still find optimal paths but explore more nodes.
                    </p>
                </div>

                <!-- Open/Closed Lists Tab -->
                <div id="tab-lists" class="info-tab-content">
                    <div class="lists-container">
                        <div class="list-section">
                            <h5><i class="fa fa-folder-open"></i> Open List <span id="open-count" class="badge">0</span></h5>
                            <div id="open-list" class="node-list">
                                <div class="list-empty">No nodes yet</div>
                            </div>
                        </div>
                        <div class="list-section">
                            <h5><i class="fa fa-folder"></i> Closed List <span id="closed-count" class="badge">0</span></h5>
                            <div id="closed-list" class="node-list">
                                <div class="list-empty">No nodes yet</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Execution Log Tab -->
                <div id="tab-log" class="info-tab-content">
                    <div class="log-header">
                        <button id="btn-clear-log" class="btn btn-xs btn-default pull-right">
                            <i class="fa fa-trash"></i> Clear
                        </button>
                    </div>
                    <div id="execution-log" class="execution-log">
                        <div class="log-entry log-info">
                            <span class="log-icon"><i class="fa fa-info-circle"></i></span>
                            <span class="log-message">Draw walls, place start/goal, then click Solve to begin.</span>
                        </div>
                    </div>
                </div>

                <!-- Compare Tab -->
                <div id="tab-compare" class="info-tab-content">
                    <div class="compare-controls">
                        <button id="btn-run-comparison" class="btn btn-sm btn-default">
                            <i class="fa fa-refresh"></i> Refresh
                        </button>
                    </div>
                    <div class="compare-table-container">
                        <table id="comparison-table" class="table table-bordered table-striped table-condensed">
                            <thead>
                                <tr>
                                    <th>Heuristic</th>
                                    <th>Explored</th>
                                    <th>Discovered</th>
                                    <th>Path Len</th>
                                    <th>Path Cost</th>
                                    <th>Time (ms)</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                    <p class="compare-hint">
                        <i class="fa fa-lightbulb-o"></i> Click a row to load that algorithm's visualization.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
